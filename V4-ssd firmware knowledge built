function closeUnbalancedHtmlTags_(html) {
 html = String(html || "");

 // If the model already started a sign-off, repair the content before it so
 // the sign-off cannot remain inside a truncated table.
 var signOffMatch = html.match(/(?:best regards|kind regards|warm regards|regards|sincerely|cheers),?/i);
 var content = signOffMatch ? html.substring(0, signOffMatch.index) : html;
 var tail = signOffMatch ? html.substring(signOffMatch.index) : "";

 // Close inner elements before outer elements. This order is important:
 // </td></tr></table> is valid, whereas closing </table> first is not.
 var tagsToCheck = ["td", "th", "tr", "table"];
 for (var i = 0; i < tagsToCheck.length; i++) {
  var tag = tagsToCheck[i];
  var openCount = (content.match(new RegExp("<" + tag + "(?:\\s[^>]*)?>", "gi")) || []).length;
  var closeCount = (content.match(new RegExp("</" + tag + ">", "gi")) || []).length;
  var missing = Math.max(0, openCount - closeCount);
  for (var j = 0; j < missing; j++) {
   content += "</" + tag + ">";
  }
 }
 return content + tail;
}

function enforceConfiguredSignOff_(html) {
