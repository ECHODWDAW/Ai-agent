    error: "",
    reply: "Forwarded to human support: " + classification.escalationReason,
    docsUsed: knowledgeContext.docsUsed,
    category: classification.category,
    productLine: classification.productLine,
    filesUsed: knowledgeContext.filesUsed || "",
    claudeModel: LAST_CLAUDE_MODEL_USED_,
    escalationReason: classification.escalationReason,
   });
   return;
  }

  var docImages = (weakKnowledgeContext && CONFIG.DISABLE_IMAGES_WHEN_CONTEXT_IS_WEAK)
   ? []
   : collectInlineImagesForCustomerNeed_(subject, latestBody, matchedFiles);
  var emailHtml = buildEmailHtmlWithImages_(aiReply, docImages, subject, latestBody);
  var replyOptions = buildReplyOptions_(emailHtml, docImages, ccRecipients);
  var recipientLists = buildUnifiedReplyRecipientLists_(sender, toRecipients, ccRecipients);
  logPreSendBodyDiagnostics_(aiReply, emailHtml, replyOptions.body, docImages);

  var status;
  if (CONFIG.ENABLE_AUTO_REPLY) {
   if (shouldUseNativeReplyAll_()) {
    try {
     thread.replyAll(replyOptions.body || "", replyOptions);
    } catch (replyAllError) {
     log(" Native replyAll failed; falling back to configured send path: " + replyAllError.message);
     if (CONFIG.ENABLE_UNIFIED_GMAIL_API_SEND) {
      sendUnifiedThreadReply_(thread, message, subject, emailHtml, docImages, recipientLists);
     } else {
      message.reply(replyOptions.body || "", replyOptions);
     }
    }
   } else if (CONFIG.ENABLE_UNIFIED_GMAIL_API_SEND) {
    sendUnifiedThreadReply_(thread, message, subject, emailHtml, docImages, recipientLists);
   } else {
    message.reply(replyOptions.body || "", replyOptions);
   }
   status = "SENT";
   log(" Reply sent to " + recipientLists.to.join(", ") + " with " + Math.min(docImages.length, CONFIG.MAX_INLINE_DOC_IMAGES) + " inline image(s)");
  } else {
   if (shouldUseNativeReplyAll_()) {
    thread.createDraftReplyAll(replyOptions.body || "", replyOptions);
   } else {
    GmailApp.createDraft(recipientLists.to.join(","), makeReplySubject_(subject), replyOptions.body || "", replyOptions);
   }
   status = "DRAFT";
   log(" Auto-reply is OFF; draft created for " + recipientLists.to.join(", ") + " with " + Math.min(docImages.length, CONFIG.MAX_INLINE_DOC_IMAGES) + " inline image(s)");
  }

  thread.markRead();
  applyLabel(thread, CONFIG.PROCESSED_LABEL);

  logToSheet({
   timestamp: new Date(),
   sender: sender,
   subject: subject,
   status: status,
   error: "",
   reply: aiReply.substring(0, 500),
   docsUsed: knowledgeContext.docsUsed,
   category: classification.category,
   productLine: classification.productLine,
   filesUsed: knowledgeContext.filesUsed || "",
   claudeModel: LAST_CLAUDE_MODEL_USED_,
   escalationReason: classification.escalationReason || "",
  });

 } catch (error) {
  log(" Processing failed: " + error.message);
  if (error && error.stack) log(" Stack: " + error.stack);
  var tid = thread.getId();
  var startCount = thread.getMessageCount();
  var prev = getThreadState_(tid);
  var attempts = ((prev && prev.attempts) || 0) + 1;
  if (attempts >= MAX_PROCESSING_ATTEMPTS_) {
   // Retry cap reached: quarantine this conversation state so it cannot
   // burn another model call until the customer sends a new message.
   log(" Retry cap (" + MAX_PROCESSING_ATTEMPTS_ + ") reached; quarantining thread and alerting support.");
   setThreadState_(tid, startCount, attempts);
   try {
    applyLabel(thread, CONFIG.PROCESSED_LABEL);
    thread.markRead();
   } catch (labelErr) {}
   notifyFailure_("Email quarantined after " + attempts + " failed attempts", error, {
    sender: message.getFrom(),
    subject: message.getSubject(),
   });
  } else {
   // Record the failed attempt but keep the stored count below the live
   // count so the filter allows one more retry next cycle.
   setThreadState_(tid, startCount - 1, attempts);
   thread.markUnread();
  }
  throw error;
 }
}


