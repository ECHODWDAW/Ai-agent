function getAdaptiveReplyLimit_(subject, body, knowledgeContext) {
 var queryText = ((subject || "") + " " + (body || "")).toLowerCase();
 var text = (queryText + " " + (knowledgeContext || "")).toLowerCase();
 var limit = CONFIG.MAX_REPLY_CHARS;

 if (isProductInfoQuestion_(queryText) && !isGuidedUseRequestText_(queryText) && !isSupportRequestText_(queryText) && !containsAnyText_(queryText, ["price", "pricing", "cost", "quote", "quotation", "how much"])) {
