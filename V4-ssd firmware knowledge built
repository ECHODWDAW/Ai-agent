}


// ============================================================================
// SECTION 8 OF 20: INLINE IMAGE SELECTION
// Choose safe and relevant product or screenshot images to embed in replies.
// ============================================================================

function collectInlineImagesForCustomerNeed_(subject, body, matchedFiles) {
 var images = [];
 if (!shouldEmbedInlineImagesForQuery_(subject, body)) {
  log("Inline images skipped because the customer did not explicitly ask for a visual.");
  return images;
 }
 var candidates = getImageCandidateFiles_(subject, body, matchedFiles);

 for (var i = 0; i < candidates.length && images.length < CONFIG.MAX_INLINE_DOC_IMAGES; i++) {
  var fileMeta = candidates[i];

  try {
   if (fileMeta.mimeType === "application/vnd.google-apps.document") {
    var docImages = extractImagesFromDoc_(fileMeta.id);
    for (var j = 0; j < docImages.length && images.length < CONFIG.MAX_INLINE_DOC_IMAGES; j++) {
     images.push(docImages[j]);
    }
   } else if (isImageMimeType_(fileMeta.mimeType)) {
    var imageBlob = DriveApp.getFileById(fileMeta.id).getBlob();
    if (isEmbeddableImageBlob_(imageBlob)) images.push(imageBlob);
   }
  } catch (e) {
   log('Could not extract images from "' + fileMeta.name + '": ' + e.message);
  }
 }

 if (images.length > 0) {
  log("Embedding " + images.length + " related documentation image(s)");
 } else if (candidates.length > 0) {
  log("Image candidates were found, but none contained embeddable image blobs.");
 } else {
  log("No image candidates found in the approved knowledge base.");
 }
 return images;
}

function collectInlineImagesFromMatchedDocs_(matchedFiles) {
 return collectInlineImagesForCustomerNeed_("", "", matchedFiles);
}

function getImageCandidateFiles_(subject, body, matchedFiles) {
 var allFiles = getKnowledgeBaseIndex_();
 var queryText = subject + " " + body;
 var intent = detectCustomerProductIntent_(queryText);
 var allowComparative = isComparisonQuery_(queryText);
 var seen = {};
 var candidates = [];

 function addCandidate(fileMeta, baseScore, reason) {
  if (!fileMeta || seen[fileMeta.id]) return;
  if (isDisabledProductFile_(fileMeta)) return;
  if (!allowComparative && isComparativeFile_(fileMeta)) return;
  if (!isCandidateAllowedForIntent_(fileMeta, intent)) return;
  seen[fileMeta.id] = true;
  candidates.push({
   file: fileMeta,
   score: baseScore + scoreImageCandidate_(fileMeta, intent),
   reason: reason,
  });
 }

 for (var i = 0; i < matchedFiles.length; i++) {
  addCandidate(matchedFiles[i], 15, "matched_answer_file");
 }

 for (var j = 0; j < allFiles.length; j++) {
  var score = scoreImageCandidate_(allFiles[j], intent);
  if (score >= CONFIG.MIN_IMAGE_CANDIDATE_SCORE) addCandidate(allFiles[j], 0, "image_search");
 }

 candidates.sort(function(a, b) { return b.score - a.score; });
 var selected = candidates
  .filter(function(item) { return item.reason === "matched_answer_file" || item.score > 0; })
  .slice(0, CONFIG.MAX_IMAGE_FILES_TO_SCAN)
  .map(function(item) { return item.file; });
 if (selected.length > 0) {
  log("Image search intent: " + intent.label + "; scanning " + selected.length + " candidate file(s)");
  log("Image candidates: " + selected.map(function(file) { return file.name; }).join(" | "));
 } else {
  log("Image search intent: " + intent.label + "; no same-product image candidates found.");
 }
 return selected;
}

