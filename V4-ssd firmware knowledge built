  SWIFT_BANNER_BLOB_CACHE_ = null;
  SWIFT_BANNER_BLOB_CACHE_LOADED_ = true;
  return null;
 }
}

function buildUnifiedReplyRecipientLists_(sender, toRecipients, ccRecipients) {
 var activeUser = getSenderEmail_();
 var toList = [extractEmailAddress(sender)].concat(parseRecipientList_(toRecipients));
 var ccList = CONFIG.ENABLE_CC_SUPPORT ? filterCcRecipients_(ccRecipients) : [];

 toList = uniqueEmails_(toList).filter(function(email) {
  return email.toLowerCase() !== activeUser.toLowerCase();
 });
 if (toList.length === 0) {
  var senderEmail = extractEmailAddress(sender);
  if (senderEmail) {
   log("Unified reply recipient list was empty after self-filtering; falling back to sender for self-test thread.");
   toList = [senderEmail];
  }
 }

 var toLookup = {};
 for (var i = 0; i < toList.length; i++) {
  toLookup[toList[i].toLowerCase()] = true;
 }

 ccList = uniqueEmails_(ccList).filter(function(email) {
  var lower = email.toLowerCase();
  return lower !== activeUser.toLowerCase() && !toLookup[lower];
 });

 return { to: toList, cc: ccList };
}

function sendUnifiedThreadReply_(thread, message, subject, emailHtml, images, recipientLists) {
 if (recipientLists.to.length === 0) {
  throw new Error("No recipients available for unified Gmail API reply.");
 }

 var rawEmail = buildRawMimeReply_(message, subject, emailHtml, images, recipientLists);
 var payload = {
  raw: Utilities.base64EncodeWebSafe(rawEmail, Utilities.Charset.UTF_8),
  threadId: thread.getId(),
 };

 var response = UrlFetchApp.fetch("https://www.googleapis.com/gmail/v1/users/me/messages/send", {
  method: "post",
  contentType: "application/json",
  headers: { Authorization: "Bearer " + ScriptApp.getOAuthToken() },
  payload: JSON.stringify(payload),
  muteHttpExceptions: true,
 });

 if (response.getResponseCode() < 200 || response.getResponseCode() >= 300) {
  throw new Error("Gmail API send failed: HTTP " + response.getResponseCode() + " - " + response.getContentText());
 }
}

function buildRawMimeReply_(message, subject, emailHtml, images, recipientLists) {
 var inReplyTo = getMessageHeader_(message, "Message-ID");
 var references = buildReferencesHeader_(message, inReplyTo);
 var headers = [
  "From: " + getSenderEmail_(),
  "To: " + recipientLists.to.join(", "),
 ];

 if (CONFIG.ENABLE_CC_SUPPORT && recipientLists.cc.length > 0) headers.push("Cc: " + recipientLists.cc.join(", "));
 headers.push("Subject: " + encodeMimeHeader_(makeReplySubject_(subject)));
 if (inReplyTo) {
  headers.push("In-Reply-To: " + inReplyTo);
  headers.push("References: " + references);
 }
 headers.push("MIME-Version: 1.0");

 if (!images || images.length === 0) {
  headers.push('Content-Type: text/html; charset="UTF-8"');
  headers.push("Content-Transfer-Encoding: base64");
  return headers.join("\r\n") + "\r\n\r\n" + encodeMimeText_(emailHtml);
 }

 var boundary = "xphy_related_" + Utilities.getUuid();
 headers.push('Content-Type: multipart/related; boundary="' + boundary + '"');

 var body = headers.join("\r\n") + "\r\n\r\n"
  + "--" + boundary + "\r\n"
  + 'Content-Type: text/html; charset="UTF-8"\r\n'
  + "Content-Transfer-Encoding: base64\r\n\r\n"
  + encodeMimeText_(emailHtml) + "\r\n";

 for (var i = 0; i < Math.min(images.length, CONFIG.MAX_INLINE_DOC_IMAGES); i++) {
  var blob = images[i];
  if (!isEmbeddableImageBlob_(blob)) continue;
  var contentType = normalizeImageContentType_(blob.getContentType());
  var filename = sanitizeMimeFilename_(blob.getName() || ("kb_image_" + i + imageExtensionForContentType_(contentType)));
  body += "--" + boundary + "\r\n"
   + "Content-Type: " + contentType + '; name="' + filename + '"\r\n'
   + "Content-Transfer-Encoding: base64\r\n"
   + "Content-ID: <kb_image_" + i + ">\r\n"
   + "X-Attachment-Id: kb_image_" + i + "\r\n"
   + "Content-Disposition: inline; filename=\"" + filename + "\"\r\n\r\n"
   + chunkBase64_(Utilities.base64Encode(blob.getBytes())) + "\r\n";
 }

 return body + "--" + boundary + "--";
}

function encodeMimeText_(text) {
 return chunkBase64_(Utilities.base64Encode(String(text || ""), Utilities.Charset.UTF_8));
}

function getMessageHeader_(message, headerName) {
 try {
  return message.getHeader(headerName) || "";
 } catch (e) {
  return "";
 }
}

function buildReferencesHeader_(message, inReplyTo) {
 var existingReferences = getMessageHeader_(message, "References");
 if (existingReferences && inReplyTo && existingReferences.indexOf(inReplyTo) < 0) {
  return existingReferences + " " + inReplyTo;
 }
 return existingReferences || inReplyTo || "";
}

function getSenderEmail_() {
 return Session.getActiveUser().getEmail() || Session.getEffectiveUser().getEmail();
}

function getSelfEmailSet_() {
 var emails = {};
 var active = "";
 var effective = "";
 try {
  active = Session.getActiveUser().getEmail() || "";
 } catch (e) { }
 try {
  effective = Session.getEffectiveUser().getEmail() || "";
 } catch (e2) { }

 [active, effective, CONFIG.ESCALATION_EMAIL, CONFIG.ALERT_EMAIL].forEach(function(email) {
  email = extractEmailAddress(email);
  if (email) emails[email.toLowerCase()] = true;
 });

 var signOffEmails = String(CONFIG.SUPPORT_SIGN_OFF || "").match(/[A-Z0-9._%+-]+@[A-Z0-9.-]+\.[A-Z]{2,}/ig) || [];
 for (var i = 0; i < signOffEmails.length; i++) {
  emails[signOffEmails[i].toLowerCase()] = true;
 }

 return emails;
}

function makeReplySubject_(subject) {
 subject = String(subject || "").trim();
 if (!subject) return "";
 return /^re:/i.test(subject) ? subject : "Re: " + subject;
}

function encodeMimeHeader_(value) {
 if (/^[\x00-\x7F]*$/.test(value)) return value;
 return "=?UTF-8?B?" + Utilities.base64Encode(value, Utilities.Charset.UTF_8) + "?=";
}

function chunkBase64_(text) {
 return text.replace(/.{1,76}/g, "$&\r\n").trim();
}

function isEmbeddableImageBlob_(blob) {
 if (!blob) return false;
 var contentType = String(blob.getContentType() || "").toLowerCase();
 return contentType.indexOf("image/") === 0;
}

function isImageMimeType_(mimeType) {
 return String(mimeType || "").toLowerCase().indexOf("image/") === 0;
}

function normalizeImageContentType_(contentType) {
 contentType = String(contentType || "").toLowerCase();
 if (contentType.indexOf("image/") === 0) return contentType;
 return "image/png";
}

function imageExtensionForContentType_(contentType) {
 if (contentType === "image/jpeg" || contentType === "image/jpg") return ".jpg";
 if (contentType === "image/gif") return ".gif";
 if (contentType === "image/webp") return ".webp";
 return ".png";
}

function sanitizeMimeFilename_(filename) {
 return String(filename || "image.png")
  .replace(/[\\\/:*?"<>|\r\n]+/g, "_")
  .replace(/[^\x20-\x7E]/g, "_");
}


// ============================================================================
// SECTION 11 OF 20: GENERAL GMAIL AND RECIPIENT HELPERS
// Deduplicate/filter recipients, manage labels, parse sender names/emails, and normalize names.
// ============================================================================

function uniqueEmails_(emails) {
 var seen = {};
 var result = [];
 for (var i = 0; i < emails.length; i++) {
  var email = extractEmailAddress(emails[i]).trim();
  if (!email || email.indexOf("@") < 0) continue;
  var key = email.toLowerCase();
  if (seen[key]) continue;
  seen[key] = true;
  result.push(email);
 }
 return result;
}

function filterCcRecipients_(ccRecipients) {
 var recipients = parseRecipientList_(ccRecipients);
 var selfEmails = getSelfEmailSet_();
 return recipients.filter(function(email) {
  var lower = email.toLowerCase();
  if (selfEmails[lower]) return false;
  for (var i = 0; i < CONFIG.EXCLUDED_CC_EMAIL_KEYWORDS.length; i++) {
   if (lower.indexOf(CONFIG.EXCLUDED_CC_EMAIL_KEYWORDS[i].toLowerCase()) >= 0) return false;
  }
  return true;
 });
}

function parseRecipientList_(recipients) {
 if (!recipients) return [];
 return recipients.split(",")
  .map(function(recipient) { return extractEmailAddress(recipient); })
  .filter(function(email) { return email && email.indexOf("@") > 0; });
}

function ensureLabelExists(labelName) {
 var label = GmailApp.getUserLabelByName(labelName);
 if (!label) {
  label = GmailApp.createLabel(labelName);
  log(' Created label: "' + labelName + '"');
 }
 return label;
}

function applyLabel(thread, labelName) {
 var label = GmailApp.getUserLabelByName(labelName);
 if (label) label.addToThread(thread);
}

function removeLabel(thread, labelName) {
 var label = GmailApp.getUserLabelByName(labelName);
 if (label) label.removeFromThread(thread);
}

function extractSenderName(fromField) {
 var displayNameMatch = fromField.match(/^"?([^"<]+?)"?\s*</);
 if (displayNameMatch && displayNameMatch[1]) {
  var displayName = displayNameMatch[1].trim();
  if (displayName && displayName.indexOf("@") < 0) return displayName;
 }

 var email = extractEmailAddress(fromField);
 var localPart = email.split("@")[0].replace(/[._-]+/g, " ").trim();
 if (localPart) return toTitleCase_(localPart);

 return "there";
}

function extractEmailAddress(fromField) {
 var emailMatch = fromField.match(/<([^>]+)>/);
 return (emailMatch ? emailMatch[1] : fromField).trim();
}

function toTitleCase_(text) {
 return text.replace(/\w\S*/g, function(word) {
  return word.charAt(0).toUpperCase() + word.slice(1).toLowerCase();
 });
}


