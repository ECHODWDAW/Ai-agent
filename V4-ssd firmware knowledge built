   aiReply = callClaude(sender, senderName, subject, latestBody, knowledgeContext.text);
  }

  if (aiReply.trim() === "SKIP_THIS_EMAIL") {
   log(" Skipping not a product query");
   thread.markRead();
   applyLabel(thread, CONFIG.PROCESSED_LABEL);
   logToSheet({
    timestamp: new Date(),
    sender: sender,
    subject: subject,
    status: "SKIPPED",
    error: "",
    reply: "Not a product query",
    docsUsed: knowledgeContext.docsUsed,
    category: classification.category,
    productLine: classification.productLine,
    filesUsed: knowledgeContext.filesUsed || "",
    claudeModel: LAST_CLAUDE_MODEL_USED_,
    escalationReason: "",
   });
   return;
  }

  if (shouldEscalateReply_(aiReply)) {
   classification.escalationReason = "AI said the query was forwarded to the team";
   forwardToHuman_(message, classification.escalationReason);
  }

  if (replyBodyLooksEmpty_(aiReply)) {
   log(" Reply body looks empty after stripping greeting/sign-off - falling back to escalation acknowledgement");
   classification.escalationReason = "AI produced no substantive answer";
   forwardToHuman_(message, classification.escalationReason);

