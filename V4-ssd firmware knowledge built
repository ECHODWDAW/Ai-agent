function translatePromptRuleOnEdit_(e) {
 try {
  if (!e || !e.range) return;
  var sheet = e.range.getSheet();
  if (sheet.getName() !== CONFIG.PROMPT_RULES_SHEET_NAME) return;
  if (e.range.getRow() <= 1 || e.range.getNumRows() !== 1 || e.range.getNumColumns() !== 1) return;

  var headers = getConfigHeaderMap_(sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0]);
  var promptRequestColumn = headers.prompt_request !== undefined ? headers.prompt_request : headers.plain_english_rule;
  if (promptRequestColumn === undefined || headers.translated_rule === undefined) return;
  if (e.range.getColumn() !== promptRequestColumn + 1) return;

  var plainRule = String(e.range.getValue() || "").trim();
  if (!plainRule) return;

  var translatedCell = sheet.getRange(e.range.getRow(), headers.translated_rule + 1);
  var existingTranslatedRule = String(translatedCell.getValue() || "").trim();

  validateConfig_();
  var category = String(sheet.getRange(e.range.getRow(), (headers.category || 1) + 1).getValue() || "").trim();
  if (existingTranslatedRule) {
   if (!category && headers.category !== undefined) {
    var inferredCategory = categorizePromptRuleWithClaude_(existingTranslatedRule);
    if (inferredCategory) {
     sheet.getRange(e.range.getRow(), headers.category + 1).setValue(inferredCategory);
     clearEditableConfigCache_();
    }
   }
   return;
  }

  var translated = translatePromptRuleWithClaude_(plainRule, category);
  if (!translated.rule) return;

  if (!category && headers.category !== undefined && translated.category) {
   sheet.getRange(e.range.getRow(), headers.category + 1).setValue(translated.category);
  }
  translatedCell.setValue(translated.rule);
  if (headers.notes !== undefined) {
   var notesCell = sheet.getRange(e.range.getRow(), headers.notes + 1);
   if (!String(notesCell.getValue() || "").trim()) {
    notesCell.setValue("AI translated on " + getFormattedTimestamp_());
   }
  }
  clearEditableConfigCache_();
 } catch (err) {
  log("Prompt rule onEdit translation failed: " + err.message);
 }
}

function translatePromptRuleWithClaude_(plainRule, category) {
 var categoryInstruction = category
  ? "Use this rule category exactly: " + category
  : "Choose the best category from this list: FORMAT RULES, CONTENT RULES, LINK AND REFERENCE RULES, INTEGRATION SETUP INSTALLATION AND USER GUIDE RULES, SUPPORT PAGE RULES, PRICING RULES, SIGN OFF, SKIP RULE.";
 var prompt = "Rewrite this manager-written instruction into one clear, strict prompt rule for a customer-support AI.\n\n"
  + "Requirements:\n"
  + "- Return only valid compact JSON with keys \"category\" and \"rule\".\n"
  + "- The \"rule\" value must be exactly one rule sentence or two short sentences.\n"
  + "- Do not add facts, URLs, prices, product claims, or policies that are not in the instruction.\n"
  + "- Preserve the user's intent.\n"
  + "- Use direct instruction language such as \"For...\", \"Do not...\", or \"When...\".\n"
  + "- Do not include markdown, explanations, or extra keys.\n"
  + "- " + categoryInstruction + "\n\n"
  + "Manager instruction: " + plainRule;

 var payload = {
  model: CONFIG.CLAUDE_MODEL,
  max_tokens: 220,
  temperature: 0,
  system: "You convert plain-English business instructions into precise prompt rules for an email support agent.",
  messages: [{ role: "user", content: prompt }],
 };

 var response = UrlFetchApp.fetch("https://api.anthropic.com/v1/messages", {
  method: "post",
  contentType: "application/json",
  headers: {
   "x-api-key": CONFIG.CLAUDE_API_KEY,
   "anthropic-version": "2023-06-01",
  },
  payload: JSON.stringify(payload),
  muteHttpExceptions: true,
 });

 if (response.getResponseCode() !== 200) {
  log("Prompt rule translation failed: " + response.getContentText().substring(0, 300));
  return "";
 }

 var responseBody = JSON.parse(response.getContentText());
 var text = "";
 for (var i = 0; i < responseBody.content.length; i++) {
  if (responseBody.content[i].type === "text") text += responseBody.content[i].text;
 }

 logClaudeTokenUsage_({
  operation: "prompt_rule_translate",
  model: CONFIG.CLAUDE_MODEL,
  sender: "AI_PROMPT_RULES",
  subject: category || "auto_category",
  usage: responseBody.usage,
  responseChars: text.length,
 });

 return parseTranslatedPromptRule_(text, category);
}

function categorizePromptRuleWithClaude_(ruleText) {
 var prompt = "Choose the best category for this customer-support AI prompt rule.\n\n"
  + "Allowed categories:\n"
  + "- FORMAT RULES\n"
  + "- CONTENT RULES\n"
  + "- LINK AND REFERENCE RULES\n"
  + "- INTEGRATION SETUP INSTALLATION AND USER GUIDE RULES\n"
  + "- SUPPORT PAGE RULES\n"
  + "- PRICING RULES\n"
  + "- SIGN OFF\n"
  + "- SKIP RULE\n\n"
  + "Return only the category name. No explanation.\n\n"
  + "Rule: " + ruleText;

 var payload = {
  model: CONFIG.CLAUDE_MODEL,
  max_tokens: 80,
  temperature: 0,
  system: "You classify prompt rules into one allowed category.",
  messages: [{ role: "user", content: prompt }],
 };

 var response = UrlFetchApp.fetch("https://api.anthropic.com/v1/messages", {
  method: "post",
  contentType: "application/json",
  headers: {
   "x-api-key": CONFIG.CLAUDE_API_KEY,
   "anthropic-version": "2023-06-01",
  },
  payload: JSON.stringify(payload),
  muteHttpExceptions: true,
 });

 if (response.getResponseCode() !== 200) {
  log("Prompt rule categorization failed: " + response.getContentText().substring(0, 300));
  return "";
 }

 var responseBody = JSON.parse(response.getContentText());
 var text = "";
 for (var i = 0; i < responseBody.content.length; i++) {
  if (responseBody.content[i].type === "text") text += responseBody.content[i].text;
 }

 logClaudeTokenUsage_({
  operation: "prompt_rule_categorize",
  model: CONFIG.CLAUDE_MODEL,
  sender: "AI_PROMPT_RULES",
  subject: "auto_category",
  usage: responseBody.usage,
  responseChars: text.length,
 });

 return sanitizePromptRuleCategory_(text);
}

function sanitizeTranslatedPromptRule_(text) {
 text = String(text || "").replace(/^\s*[-*\d.)]+\s*/g, "").replace(/^["']|["']$/g, "").trim();
 text = text.replace(/\r?\n+/g, " ").replace(/\s+/g, " ").trim();
 return text;
}

function parseTranslatedPromptRule_(text, fallbackCategory) {
 var cleaned = String(text || "").trim();
 try {
  var parsed = JSON.parse(cleaned);
  return {
   category: sanitizePromptRuleCategory_(parsed.category || fallbackCategory),
   rule: sanitizeTranslatedPromptRule_(parsed.rule || ""),
  };
 } catch (e) {
  return {
   category: sanitizePromptRuleCategory_(fallbackCategory || "CONTENT RULES"),
   rule: sanitizeTranslatedPromptRule_(cleaned),
  };
 }
}

function sanitizePromptRuleCategory_(category) {
 category = String(category || "CONTENT RULES").toUpperCase().trim();
 category = category.replace(/[^A-Z0-9 ,&\/+-]/g, "").replace(/\s+/g, " ");
 if (!category) return "CONTENT RULES";
 return category;
}

