function htmlToPlainText_(html) {
 // Gmail sends multipart messages: an empty text/plain part makes some clients
 // render a blank body even when the HTML part is fine. Always supply both.
 return String(html || "")
  .replace(/<style[\s\S]*?<\/style>/gi, "")
  .replace(/<br\s*\/?>/gi, "\n")
  .replace(/<\/(p|div|h[1-6]|tr|li)>/gi, "\n")
  .replace(/<li[^>]*>/gi, "- ")
  .replace(/<a [^>]*href="([^"]*)"[^>]*>([^<]*)<\/a>/gi, "$2 ($1)")
  .replace(/<[^>]+>/g, "")
  .replace(/&nbsp;/gi, " ")
  .replace(/&amp;/gi, "&")
  .replace(/&lt;/gi, "<")
  .replace(/&gt;/gi, ">")
  .replace(/&quot;/gi, '"')
  .replace(/[ \t]{2,}/g, " ")
  .replace(/\n{3,}/g, "\n\n")
  .trim();
}

function buildReplyOptions_(emailHtml, images, ccRecipients) {
 var replyOptions = {
  htmlBody: emailHtml,
  body: htmlToPlainText_(emailHtml), // plain-text alternative so no client shows a blank body
 };
 var filteredCc = CONFIG.ENABLE_CC_SUPPORT ? filterCcRecipients_(ccRecipients) : [];
 var inlineImages = {};

 if (filteredCc.length > 0) {
  replyOptions.cc = filteredCc.join(",");
  log("CC after filtering: " + replyOptions.cc);
 }

 if (images && images.length > 0) {
  for (var i = 0; i < Math.min(images.length, CONFIG.MAX_INLINE_DOC_IMAGES); i++) {
   inlineImages["kb_image_" + i] = images[i];
  }
 }

 var swiftBanner = getSwiftBannerImage_();
 if (swiftBanner) inlineImages.swift_banner = swiftBanner;
 if (Object.keys(inlineImages).length > 0) replyOptions.inlineImages = inlineImages;

 return replyOptions;
}

function logPreSendBodyDiagnostics_(aiReply, emailHtml, plainTextBody, images) {
 var aiReplyText = htmlToPlainText_(aiReply);
 var finalPlainText = String(plainTextBody || "");
 log("DIAG D2 PRE_SEND"
  + " | model=" + (LAST_CLAUDE_MODEL_USED_ || "unknown")
  + " | images=" + ((images && images.length) || 0)
  + " | aiReplyHtmlLen=" + String(aiReply || "").length
  + " | aiReplyTextLen=" + aiReplyText.length
  + " | aiReplyLooksEmpty=" + replyBodyLooksEmpty_(aiReply)
  + " | emailHtmlLen=" + String(emailHtml || "").length
  + " | plainTextLen=" + finalPlainText.length
  + " | aiReplyTextHead=" + JSON.stringify(aiReplyText.substring(0, 240))
  + " | plainTextHead=" + JSON.stringify(finalPlainText.substring(0, 240)));
}

function shouldUseNativeReplyAll_() {
 // Native replyAll can re-add the original Cc list, including Ethan/the active account.
 // Use the controlled recipient path when CC support is enabled so filtering is respected.
 return CONFIG.ENABLE_NATIVE_REPLY_ALL_SEND && !CONFIG.ENABLE_CC_SUPPORT;
}

function getSwiftBannerImage_() {
 if (!CONFIG.SWIFT_BANNER_DRIVE_FILE_ID) return null;
 if (SWIFT_BANNER_BLOB_CACHE_LOADED_) return SWIFT_BANNER_BLOB_CACHE_;
 try {
