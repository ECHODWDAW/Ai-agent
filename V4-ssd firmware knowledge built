 cleaned = cleaned.replace(/(?:<br\s*\/?>|\s)*All prices are in USD,\s*excluding freight,\s*handling,\s*and applicable taxes\.?/ig, "");
 cleaned = cleaned.replace(salesRegex, "");

 var footer = "<br><br>" + usdSentence + "<br>" + salesSentence + "<br><br>";
 if (/Best regards,/i.test(cleaned)) {
