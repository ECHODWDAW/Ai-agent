 return normalized === "folder" || normalized === "folder root" || normalized.indexOf("shortcut") >= 0;
}

function isExcludedInventoryRow_(name, path) {
 if (isExcludedDriveName_(name, false)) return true;
 if (hasRestrictedMarker_(path)) return true;
 return hasInventoryPathHardExclude_(path);
}

function hasInventoryPathHardExclude_(path) {
 var key = normalizeExclusionName_(path);
 if (!key) return false;
 var hardPatterns = [
  "for testing use",
  "internal use for training",
  "to be uploaded",
  "deepfake internal uat",
  "old copies",
  "demo resources",
  "mc feedback form",
  "for marketing",
  "faq manager",
  "duplicate",
 ];
 for (var i = 0; i < hardPatterns.length; i++) {
