function debugInventoryRestrictionAudit_() {
 var savedInventoryId = PropertiesService.getScriptProperties().getProperty("DOCUMENT_INVENTORY_SPREADSHEET_ID");
 if (savedInventoryId) CONFIG.DOCUMENT_INVENTORY_SPREADSHEET_ID = savedInventoryId;
 if (!CONFIG.DOCUMENT_INVENTORY_SPREADSHEET_ID) {
  log("No document inventory spreadsheet ID configured.");
  return;
 }

 var counts = {
  totalRows: 0,
  usableRows: 0,
  missingNameLinkOrId: 0,
  folderRows: 0,
  restrictedByNameOrPath: 0,
  disabledProduct: 0,
  notSearchableTextSource: 0,
 };
 var examples = {};

 function addExample(reason, name, path) {
  if (!examples[reason]) examples[reason] = [];
  if (examples[reason].length < 5) examples[reason].push(String(name || "(blank)") + " | " + String(path || ""));
 }

 try {
  var spreadsheet = SpreadsheetApp.openById(CONFIG.DOCUMENT_INVENTORY_SPREADSHEET_ID);
  var sheet = spreadsheet.getSheetByName("Inventory") || spreadsheet.getSheets()[0];
  var values = sheet.getDataRange().getValues();
  if (values.length < 2) {
   log("Inventory sheet has no data rows.");
   return;
  }
  var headers = buildInventoryHeaderMap_(values[0]);

  for (var i = 1; i < values.length; i++) {
   var row = values[i];
   var name = getInventoryCell_(row, headers, "name");
   var link = getInventoryCell_(row, headers, "link");
   var type = getInventoryCell_(row, headers, "type");
   var category = getInventoryCell_(row, headers, "category");
   var productLine = getInventoryCell_(row, headers, "productline");
   var path = getInventoryCell_(row, headers, "path");
   var fileId = extractDriveIdFromUrl_(link);
   counts.totalRows++;

   if (!name || !link || !fileId) {
    counts.missingNameLinkOrId++;
    addExample("missingNameLinkOrId", name, path);
    continue;
   }
   if (isInventoryFolderType_(type)) {
    counts.folderRows++;
    addExample("folderRows", name, path);
    continue;
   }
   if (isExcludedInventoryRow_(name, path)) {
    counts.restrictedByNameOrPath++;
    addExample("restrictedByNameOrPath", name, path);
    continue;
   }

   var meta = {
    id: fileId,
    name: name,
    mimeType: inferMimeTypeFromInventoryType_(type),
    url: link,
    parentIds: [],
    parentNames: [category, productLine, path],
    category: category,
    productLine: canonicalProductLineFromInventory_(productLine, category, name),
    inventoryType: type,
    path: path,
   };
   if (isDisabledProductFile_(meta)) {
    counts.disabledProduct++;
    addExample("disabledProduct", name, path);
    continue;
   }
   if (!isSearchableKnowledgeFile_(meta)) {
    counts.notSearchableTextSource++;
    addExample("notSearchableTextSource", name, path);
   }
   counts.usableRows++;
  }

  log("Inventory restriction audit: " + JSON.stringify(counts));
  log("Restriction examples: " + JSON.stringify(examples));
 } catch (e) {
  log("Could not audit inventory restrictions: " + e.message);
 }
}

function uniqueButtons_(buttons) {
 var seen = {};
 var out = [];
 for (var i = 0; i < buttons.length; i++) {
  if (!buttons[i] || !buttons[i].url || seen[buttons[i].url]) continue;
  seen[buttons[i].url] = true;
  out.push(buttons[i]);
 }
 return out;
}


