function extractImagesFromDoc_(docId) {
 var doc = DocumentApp.openById(docId);
 var body = doc.getBody();
 var images = [];
 try {
  var bodyImages = body.getImages();
  for (var i = 0; i < bodyImages.length && images.length < CONFIG.MAX_INLINE_DOC_IMAGES; i++) {
   var blob = bodyImages[i].getBlob();
   if (isEmbeddableImageBlob_(blob)) images.push(blob);
  }
 } catch (e) { }
 if (images.length === 0) collectImagesFromElement_(body, images);
 return images;
}

function collectImagesFromElement_(element, images) {
 if (images.length >= CONFIG.MAX_INLINE_DOC_IMAGES) return;

 if (element.getType && element.getType() === DocumentApp.ElementType.INLINE_IMAGE) {
  var blob = element.asInlineImage().getBlob();
  if (isEmbeddableImageBlob_(blob)) images.push(blob);
  return;
 }

 if (!element.getNumChildren) return;
 for (var i = 0; i < element.getNumChildren() && images.length < CONFIG.MAX_INLINE_DOC_IMAGES; i++) {
  collectImagesFromElement_(element.getChild(i), images);
 }
}


