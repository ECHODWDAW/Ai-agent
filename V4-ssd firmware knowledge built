function getPricingData() {
 try {
  var cachedPricing = CacheService.getScriptCache().get(PRICING_DATA_CACHE_KEY_);
  if (cachedPricing) {
   log(" Loaded pricing data from cache");
   return cachedPricing;
  }

  var ss = SpreadsheetApp.openById(PRICING_SHEET_ID);
  var sheets = ss.getSheets();
