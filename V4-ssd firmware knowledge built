function extractFileContent(file) {
 var mimeType = file.getMimeType();

 try {
  switch (mimeType) {
   case "application/vnd.google-apps.document":
    var docContent = DocumentApp.openById(file.getId()).getBody().getText();
    return docContent.substring(0, CONFIG.MAX_CHARS_PER_FILE);

   case "application/vnd.google-apps.spreadsheet":
    return extractSheetContent(file.getId());

   case "text/plain":
   case "text/csv":
    var textContent = file.getBlob().getDataAsString();
    return textContent.substring(0, CONFIG.MAX_CHARS_PER_FILE);

   case "application/pdf":
    return extractPdfContent(file);

   case "application/vnd.openxmlformats-officedocument.wordprocessingml.document":
   case "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet":
    return extractDocxOrXlsxContent(file);

   case "application/vnd.openxmlformats-officedocument.presentationml.presentation":
    return extractPptxContent(file);

   default:
    if (isImageMimeType_(mimeType)) {
     return "[Image file available for inline embedding: " + file.getName() + "]";
    }
    log(' Unsupported type: ' + mimeType + ' for "' + file.getName() + '"');
    return null;
  }
 } catch (e) {
  log(' Could not extract "' + file.getName() + '": ' + e.message);
  return null;
 }
}

function extractSheetContent(fileId) {
 var sheet = SpreadsheetApp.openById(fileId).getSheets()[0];
 var data = sheet.getDataRange().getValues();
 var text = "";
 for (var r = 0; r < data.length; r++) {
  text += data[r].join(" | ") + "\n";
  if (text.length > CONFIG.MAX_CHARS_PER_FILE) break;
 }
 return text.substring(0, CONFIG.MAX_CHARS_PER_FILE);
}

function cleanupOldTempFiles_() {
 var cutoff = new Date(new Date().getTime() - CONFIG.TEMP_FILE_MAX_AGE_MINUTES * 60 * 1000);
 var query = 'title contains "' + CONFIG.TEMP_FILE_PREFIX + '" and trashed = false';
 var files = DriveApp.searchFiles(query);
 var removed = 0;

 while (files.hasNext()) {
  var file = files.next();
  if (file.getDateCreated() < cutoff) {
   file.setTrashed(true);
   removed++;
  }
 }

 if (removed > 0) log("Cleaned up " + removed + " stale temp file(s)");
}

function uploadAndConvertToDoc(blob, tempName) {
 var metadata = {
  name: CONFIG.TEMP_FILE_PREFIX + tempName,
  mimeType: "application/vnd.google-apps.document",
 };

 var boundary = "-------boundary" + Utilities.getUuid();

 var payload = "--" + boundary + "\r\n"
  + "Content-Type: application/json; charset=UTF-8\r\n\r\n"
  + JSON.stringify(metadata) + "\r\n"
  + "--" + boundary + "\r\n"
  + "Content-Type: " + blob.getContentType() + "\r\n"
  + "Content-Transfer-Encoding: base64\r\n\r\n"
  + Utilities.base64Encode(blob.getBytes()) + "\r\n"
  + "--" + boundary + "--";

 var options = {
  method: "post",
  contentType: "multipart/related; boundary=" + boundary,
  headers: { Authorization: "Bearer " + ScriptApp.getOAuthToken() },
  payload: payload,
  muteHttpExceptions: true,
 };

 var response = UrlFetchApp.fetch(
  "https://www.googleapis.com/upload/drive/v3/files?uploadType=multipart&ocrLanguage=en",
  options
 );

 if (response.getResponseCode() !== 200) {
  throw new Error("Drive upload failed: HTTP " + response.getResponseCode());
 }

 var result = JSON.parse(response.getContentText());

 try {
  var doc = DocumentApp.openById(result.id);
  return doc.getBody().getText();
 } finally {
  deleteDriveFile_(result.id);
 }
}

function extractPdfContent(file) {
 var text = uploadAndConvertToDoc(file.getBlob(), "ocr_" + file.getName());
 return text.substring(0, CONFIG.MAX_CHARS_PER_FILE);
}

function extractDocxOrXlsxContent(file) {
