function processNewEmails() {
 log("BUILD 2026-07-16-B (firmware answer lock + FAQ scoring + score debugger) running from: " + ScriptApp.getScriptId() + " as " + Session.getEffectiveUser().getEmail());
 var lock = LockService.getScriptLock();
 if (!lock.tryLock(5000)) {
  log(" Another agent run is already in progress; skipping this trigger.");
  return;
 }

 var startTime = new Date();
 log(" Agent run started");

 try {
  validateConfig_();
  cleanupOldTempFiles_();
  ensureLabelExists(CONFIG.PROCESSED_LABEL);
  var threads = getUnprocessedThreads();
  if (threads.length === 0) {
   log(" No new emails to process");
   return;
  }

  warmKnowledgeBaseCache_();
  log(" Found " + threads.length + " unprocessed email(s)");
  var processCount = Math.min(threads.length, CONFIG.MAX_EMAILS_PER_RUN);

  for (var i = 0; i < processCount; i++) {
   var thread = threads[i];
   var message = thread.getMessages()[thread.getMessageCount() - 1];

   try {
    processEmail(thread, message);
    // Cost firewall: remember the conversation state we just handled.
    // Fresh count includes our own reply when one was sent; capped at
    // start+1 so a customer message racing in is never masked.
    try {
     var freshCount = GmailApp.getThreadById(thread.getId()).getMessageCount();
     setThreadState_(thread.getId(), Math.min(freshCount, thread.getMessageCount() + 1), 0);
    } catch (stateErr) {
     setThreadState_(thread.getId(), thread.getMessageCount(), 0);
    }
   } catch (emailError) {
    log(' Error processing email "' + message.getSubject() + '": ' + emailError.message);
    notifyFailure_("Email processing failed", emailError, {
     sender: message.getFrom(),
     subject: message.getSubject(),
    });
    logToSheet({
     timestamp: new Date(),
     sender: message.getFrom(),
     subject: message.getSubject(),
     status: "ERROR",
     error: emailError.message,
     reply: "",
     docsUsed: "",
    });
   }
  }

  if (new Date().getMinutes() === 0) cleanupThreadStates_(); // prune once an hour
  var elapsed = ((new Date() - startTime) / 1000).toFixed(1);
  log(" Agent run complete processed " + processCount + " email(s) in " + elapsed + "s");

 } catch (error) {
  log(" Critical error: " + error.message);
  notifyFailure_("Critical AI email agent failure", error, {});
 } finally {
  lock.releaseLock();
 }
}


function processEmail(thread, message) {
 var sender = message.getFrom();
 var senderName = extractSenderName(sender);
 var subject = message.getSubject();
 var body = extractPlainText(message);
 var latestBody = extractLatestReplyText_(body);
 var toRecipients = message.getTo();
 var ccRecipients = CONFIG.ENABLE_CC_SUPPORT ? message.getCc() : "";

 log(' Processing: "' + subject + '" from ' + sender + " (name: " + senderName + ")");
 if (latestBody.length < body.length) {
  log(" Trimmed quoted thread history from " + body.length + " to " + latestBody.length + " characters for intent detection");
 }

 var classification = classifyEmail_(subject, latestBody);
 log(" Classification: " + classification.category + " / " + classification.productLine + " (confidence " + classification.confidence + ") - " + classification.reason);

 if (isProductTemporarilyDisabled_(classification.productLine)) {
  sendTemporarilyUnavailableProductReply_(thread, message, sender, senderName, subject, latestBody, toRecipients, ccRecipients, classification);
  return;
 }

 if (classification.shouldSkip) {
  thread.markRead();
  applyLabel(thread, CONFIG.PROCESSED_LABEL);
  logToSheet({
   timestamp: new Date(),
   sender: sender,
   subject: subject,
   status: "SKIPPED",
   error: "",
   reply: "Skipped by pre-classifier: " + classification.reason,
   docsUsed: 0,
   category: classification.category,
   productLine: classification.productLine,
   filesUsed: "",
   claudeModel: "",
   escalationReason: "",
  });
  return;
 }

 if (classification.shouldEscalate || needsHumanEscalation_(subject, latestBody) || isBulkPricingInquiry_(subject, latestBody)) {
  var escalationReason = classification.escalationReason || "Sentiment / risk escalation";
  if (!classification.escalationReason && isBulkPricingInquiry_(subject, latestBody)) {
   escalationReason = "Bulk/volume/reseller pricing inquiry - not in AI knowledge base";
  }
  forwardToHuman_(message, escalationReason);

  var ackReply = buildEscalationAcknowledgementReply_(senderName);
  var ackReplyOptions = buildReplyOptions_(ackReply, [], ccRecipients);
  var ackRecipientLists = buildUnifiedReplyRecipientLists_(sender, toRecipients, ccRecipients);
  var ackStatus = "ESCALATED";

  try {
   if (CONFIG.ENABLE_AUTO_REPLY) {
    if (shouldUseNativeReplyAll_()) {
     thread.replyAll(ackReplyOptions.body || htmlToPlainText_(ackReply), ackReplyOptions);
    } else if (CONFIG.ENABLE_UNIFIED_GMAIL_API_SEND) {
     sendUnifiedThreadReply_(thread, message, subject, ackReply, [], ackRecipientLists);
    } else {
     message.reply(ackReplyOptions.body || htmlToPlainText_(ackReply), ackReplyOptions);
    }
    ackStatus = "ESCALATED_WITH_ACK";
   } else {
    if (shouldUseNativeReplyAll_()) {
     thread.createDraftReplyAll(ackReplyOptions.body || htmlToPlainText_(ackReply), ackReplyOptions);
    } else {
     GmailApp.createDraft(ackRecipientLists.to.join(","), makeReplySubject_(subject), ackReplyOptions.body || htmlToPlainText_(ackReply), ackReplyOptions);
    }
    ackStatus = "ESCALATED_DRAFT_ACK";
   }
  } catch (ackError) {
   log(" Could not send escalation acknowledgement: " + ackError.message);
   ackStatus = "ESCALATED_ACK_FAILED";
  }

  thread.markRead();
  applyLabel(thread, CONFIG.PROCESSED_LABEL);
  logToSheet({
   timestamp: new Date(),
   sender: sender,
   subject: subject,
   status: ackStatus,
   error: "",
   reply: "Forwarded to human support: " + escalationReason,
   docsUsed: 0,
   category: classification.category,
   productLine: classification.productLine,
   filesUsed: "",
   claudeModel: "",
   escalationReason: escalationReason,
  });
  return;
 }

 try {
  var knowledgeContext = searchKnowledgeBase(subject, latestBody, classification);
  var matchedFiles = knowledgeContext.files || [];
  log(" Found " + knowledgeContext.docsUsed + " relevant document(s)");

  var weakKnowledgeContext = !isKnowledgeContextStrongEnough_(knowledgeContext, classification, subject, latestBody);
  var aiReply;
  if (weakKnowledgeContext) {
   classification.escalationReason = "Insufficient approved documentation for direct AI answer";
   aiReply = buildLimitedDocumentationReply_(senderName, classification.productLine);
   LAST_CLAUDE_MODEL_USED_ = "SKIPPED_WEAK_CONTEXT";
