function formatPricingTables_(html) {
 var cleaned = String(html || "");
 if (cleaned.toLowerCase().indexOf("<table") < 0) return cleaned;

 cleaned = cleaned.replace(/<table\b[^>]*>([\s\S]*?)<\/table>/gi, function(tableMatch, tableBody) {
  var rows = [];
  tableBody.replace(/<tr\b[^>]*>([\s\S]*?)<\/tr>/gi, function(rowMatch, rowBody) {
   rows.push(rowBody);
   return rowMatch;
  });
  if (rows.length === 0) return tableMatch;

  var firstRowCellCount = (rows[0].match(/<(?:td|th)\b/gi) || []).length;
  var hasCapacityHeader = firstRowCellCount > 1;
  var rowIndex = 0;
  var formattedBody = tableBody.replace(/<tr\b[^>]*>([\s\S]*?)<\/tr>/gi, function(rowMatch, rowBody) {
   var cells = [];
   rowBody.replace(/<(td|th)\b[^>]*>([\s\S]*?)<\/\1>/gi, function(cellMatch, tagName, content) {
    cells.push({ tagName: tagName.toLowerCase(), content: content });
    return cellMatch;
   });
   if (cells.length === 0) {
    rowIndex++;
    return rowMatch;
   }

   var isHeaderRow = hasCapacityHeader && rowIndex === 0;
   var rebuiltCells = [];
   for (var i = 0; i < cells.length; i++) {
    var isLast = i === cells.length - 1;
    var padding = isHeaderRow
     ? (isLast ? "6px 0" : "6px 24px 6px 0")
     : (isLast ? "8px 0" : "8px 24px 8px 0");
    var style = "padding:" + padding + ";border-bottom:1px solid " + (isHeaderRow ? "#ddd" : "#eee") + ";text-align:left;vertical-align:top;";
    if (isHeaderRow) style += "font-weight:bold;";
    rebuiltCells.push("<td style=\"" + style + "\">" + cells[i].content + "</td>");
   }
   rowIndex++;
   return "<tr>" + rebuiltCells.join("") + "</tr>";
  });

  return '<table style="width:100%;border-collapse:collapse;font-family:Arial,sans-serif;font-size:14px;">'
   + formattedBody
   + "</table>";
 });
 return cleaned;
}

