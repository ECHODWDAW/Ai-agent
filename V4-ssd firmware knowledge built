function appendMissingPromptRulesFromSystemPrompt_() {
 loadSavedConfigSpreadsheetId_();
 if (!CONFIG.CONFIG_SPREADSHEET_ID) throw new Error("Run setupEditableConfigTemplate_() first, or set CONFIG_SPREADSHEET_ID.");
 upgradePromptRulesSheetForTranslator_();
 var spreadsheet = SpreadsheetApp.openById(CONFIG.CONFIG_SPREADSHEET_ID);
 var sheet = spreadsheet.getSheetByName(CONFIG.PROMPT_RULES_SHEET_NAME) || spreadsheet.insertSheet(CONFIG.PROMPT_RULES_SHEET_NAME);
 var defaultRows = getDefaultPromptRuleRows_();

 if (sheet.getLastRow() === 0) {
  var emptyHeaders = getPromptRuleSheetHeaders_();
  sheet.getRange(1, 1, 1, emptyHeaders.length).setValues([emptyHeaders]);
  sheet.getRange(1, 1, 1, emptyHeaders.length).setFontWeight("bold");
 }

 var existing = {};
 if (sheet.getLastRow() > 1) {
  var headers = getConfigHeaderMap_(sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0]);
  var currentRows = sheet.getRange(2, 1, sheet.getLastRow() - 1, sheet.getLastColumn()).getValues();
  for (var i = 0; i < currentRows.length; i++) {
   var key = normalizePromptRuleKey_(
    getConfigCell_(currentRows[i], headers, "section", 2) || getConfigCell_(currentRows[i], headers, "category", 2),
    getConfigCell_(currentRows[i], headers, "translated_rule", 3) || getConfigCell_(currentRows[i], headers, "rule", 2)
   );
   if (key) existing[key] = true;
  }
 }

 var rowsToAppend = [];
 for (var j = 0; j < defaultRows.length; j++) {
  var defaultKey = normalizePromptRuleKey_(defaultRows[j][2], defaultRows[j][3]);
  if (defaultKey && !existing[defaultKey]) {
   rowsToAppend.push(defaultRows[j]);
   existing[defaultKey] = true;
  }
 }

 if (rowsToAppend.length > 0) {
  sheet.getRange(sheet.getLastRow() + 1, 1, rowsToAppend.length, getPromptRuleSheetHeaders_().length).setValues(rowsToAppend);
  sheet.autoResizeColumns(1, getPromptRuleSheetHeaders_().length);
 }

 clearEditableConfigCache_();
 log("Appended " + rowsToAppend.length + " missing AI_PROMPT_RULES row(s) from SYSTEM_PROMPT.");
}

