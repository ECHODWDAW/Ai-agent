function upgradePromptRulesSheetForTranslator_() {
 loadSavedConfigSpreadsheetId_();
 if (!CONFIG.CONFIG_SPREADSHEET_ID) throw new Error("Run setupEditableConfigTemplate_() first, or set CONFIG_SPREADSHEET_ID.");
 var spreadsheet = SpreadsheetApp.openById(CONFIG.CONFIG_SPREADSHEET_ID);
 var sheet = spreadsheet.getSheetByName(CONFIG.PROMPT_RULES_SHEET_NAME) || spreadsheet.insertSheet(CONFIG.PROMPT_RULES_SHEET_NAME);
 var targetHeaders = getPromptRuleSheetHeaders_();

 if (sheet.getLastRow() === 0) {
  sheet.getRange(1, 1, 1, targetHeaders.length).setValues([targetHeaders]);
  formatEditableConfigSheet_(sheet, targetHeaders.length);
  return;
 }

 var currentValues = sheet.getDataRange().getValues();
 var headers = getConfigHeaderMap_(currentValues[0]);
 if (headers.translated_rule !== undefined && (headers.prompt_request !== undefined || headers.plain_english_rule !== undefined) && headers.category !== undefined) {
  formatEditableConfigSheet_(sheet, targetHeaders.length);
  return;
 }

 var migrated = [targetHeaders];
 for (var i = 1; i < currentValues.length; i++) {
  var row = currentValues[i];
  var enabled = getConfigCell_(row, headers, "enabled", 0);
  var category = getConfigCell_(row, headers, "category", -1) || getConfigCell_(row, headers, "section", 1);
  var translatedRule = getConfigCell_(row, headers, "translated_rule", -1) || getConfigCell_(row, headers, "ai_translated_rule", -1) || getConfigCell_(row, headers, "rule", 2);
  var plainRule = getConfigCell_(row, headers, "prompt_request", -1) || getConfigCell_(row, headers, "plain_english_rule", -1);
  var notes = getConfigCell_(row, headers, "notes", -1) || (translatedRule ? "Existing system rule" : "");
  if (!enabled && !category && !translatedRule && !plainRule) continue;
  migrated.push([enabled, plainRule, category, translatedRule, notes]);
 }

 sheet.clear();
 sheet.getRange(1, 1, migrated.length, targetHeaders.length).setValues(migrated);
 formatEditableConfigSheet_(sheet, targetHeaders.length);
 clearEditableConfigCache_();
 log("Upgraded AI_PROMPT_RULES to manager-friendly prompt translator columns.");
}

function translateNewPromptRules_() {
 validateConfig_();
 upgradePromptRulesSheetForTranslator_();
 var spreadsheet = SpreadsheetApp.openById(CONFIG.CONFIG_SPREADSHEET_ID);
 var sheet = spreadsheet.getSheetByName(CONFIG.PROMPT_RULES_SHEET_NAME);
 var values = sheet.getDataRange().getValues();
 if (values.length < 2) {
  log("No prompt rules to translate.");
  return;
 }

 var headers = getConfigHeaderMap_(values[0]);
 var translatedCount = 0;
 var categorizedCount = 0;

 for (var i = 1; i < values.length; i++) {
  var row = values[i];
  var plainRule = String(getConfigCell_(row, headers, "prompt_request", 2) || getConfigCell_(row, headers, "plain_english_rule", -1) || "").trim();
  var translatedRule = String(getConfigCell_(row, headers, "translated_rule", 3) || "").trim();
  var category = String(getConfigCell_(row, headers, "category", 2) || "").trim();

  if (!category && translatedRule && headers.category !== undefined) {
   var inferredCategory = categorizePromptRuleWithClaude_(translatedRule);
   if (inferredCategory) {
    sheet.getRange(i + 1, headers.category + 1).setValue(inferredCategory);
    categorizedCount++;
   }
   continue;
  }

  if (!plainRule || translatedRule) continue;

  var translated = translatePromptRuleWithClaude_(plainRule, category);
  if (!translated.rule) continue;

  if (!category && headers.category !== undefined && translated.category) {
   sheet.getRange(i + 1, headers.category + 1).setValue(translated.category);
  }
  sheet.getRange(i + 1, headers.translated_rule + 1).setValue(translated.rule);
  if (headers.notes !== undefined && !getConfigCell_(row, headers, "notes", 4)) {
   sheet.getRange(i + 1, headers.notes + 1).setValue("AI translated on " + getFormattedTimestamp_());
  }
  translatedCount++;
 }

 clearEditableConfigCache_();
 log("Translated " + translatedCount + " new prompt request(s); categorized " + categorizedCount + " existing rule(s).");
}

