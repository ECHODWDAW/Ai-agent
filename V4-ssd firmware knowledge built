function detectCustomerProductIntent_(text) {
 text = normalizeProductPhrases_(text);
 var profiles = getProductIntentProfiles_();

 var best = { label: "General X-PHY", terms: [], strongTerms: [], weakTerms: [], score: 0, strongScore: 0, weakScore: 0 };
 for (var i = 0; i < profiles.length; i++) {
  var scored = scoreProductProfile_(text, profiles[i]);
  if (scored.score > best.score || (scored.score === best.score && scored.strongScore > best.strongScore)) {
   best = {
    label: profiles[i].label,
    terms: profiles[i].terms,
    strongTerms: profiles[i].strongTerms || [],
    weakTerms: profiles[i].weakTerms || [],
    score: scored.score,
    strongScore: scored.strongScore,
    weakScore: scored.weakScore,
   };
  }
 }
 return best;
}

function detectCustomerProductIntents_(text) {
 text = normalizeProductPhrases_(text);
 var profiles = getProductIntentProfiles_();
 var matches = [];
 for (var i = 0; i < profiles.length; i++) {
  var scored = scoreProductProfile_(text, profiles[i]);
  var firstIndex = -1;
  for (var j = 0; j < profiles[i].terms.length; j++) {
   var termIndex = text.indexOf(profiles[i].terms[j]);
   if (termIndex >= 0) {
    if (firstIndex < 0 || termIndex < firstIndex) firstIndex = termIndex;
   }
  }
  if (scored.score > 0) {
   matches.push({
    label: profiles[i].label,
    terms: profiles[i].terms,
    strongTerms: profiles[i].strongTerms || [],
    weakTerms: profiles[i].weakTerms || [],
    score: scored.score,
    strongScore: scored.strongScore,
    weakScore: scored.weakScore,
    firstIndex: firstIndex,
   });
  }
 }
 matches.sort(function(a, b) {
  if (a.firstIndex !== b.firstIndex) return a.firstIndex - b.firstIndex;
  return b.score - a.score;
 });
 return matches;
}

function normalizeProductPhrases_(text) {
 return String(text || "")
  .toLowerCase()
  .replace(/\bserver\s+defender\b/g, "server_defender")
  .replace(/\bdeep\s*fake\s+detector\b/g, "deepfake_detector")
  .replace(/\bdeepfake\s+detector\b/g, "deepfake_detector")
  .replace(/\bmanagement\s+console\b/g, "management_console")
  .replace(/\bguard\s+pc\s+application\b/g, "guard_pc_application")
  .replace(/\bguard\s+pc\b/g, "guard_pc")
  .replace(/\bsecure\s+ssd\b/g, "secure_ssd")
  .replace(/\bcyber\s+secure\s+ssd\b/g, "secure_ssd")
  .replace(/\bcipher\s+vault\b/g, "cipher_vault")
  .replace(/\bsecure\s+usb\b/g, "secure_usb")
  .replace(/\btrust\s+sign\b/g, "trustsign")
  .replace(/\btrust\s+rom\b/g, "trustrom")
  .replace(/\bsecure\s+laptop\b/g, "secure_laptop");
}

function scoreProductProfile_(text, profile) {
 var strongScore = countMatchedTerms_(text, profile.strongTerms || []);
 var weakScore = countMatchedTerms_(text, profile.weakTerms || []);
 return {
  strongScore: strongScore,
  weakScore: weakScore,
  score: strongScore * 3 + weakScore,
 };
}

function countMatchedTerms_(text, terms) {
 var count = 0;
 for (var i = 0; i < terms.length; i++) {
  if (text.indexOf(terms[i]) >= 0) count++;
 }
 return count;
}

