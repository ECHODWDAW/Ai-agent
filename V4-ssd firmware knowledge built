// ============================================================================
// SECTION 13 OF 20: KNOWLEDGE BASE SEARCH AND SCORING
// Find relevant KB files, add pricing/processor/general context, and score documents against email intent.
// ============================================================================

function searchKnowledgeBase(subject, body, classification) {
 classification = classification || classifyEmail_(subject, body);
 var emailText = (subject + " " + body).toLowerCase();

 // A simple DFD overview must not inherit installation/specification content
 // merely because those documents contain strong DFD keyword matches.
 if (isPureProductOverviewQuery_(emailText, classification.productLine)) {
  log(" Pure " + classification.productLine + " overview detected; using curated overview context only");
  return {
   text: getProductOverviewContext_(classification.productLine),
   files: [],
   docsUsed: 1,
   filesUsed: "Curated " + classification.productLine + " Product Overview",
   classification: classification,
  };
 }

 var keywords = extractKeywords(subject + " " + body);
 log(" Keywords: " + keywords.join(", "));

 var allFiles = getKnowledgeBaseIndex_();
 var lookupCount = allFiles.filter(function(file) { return file.sourceType === "kb_lookup_index"; }).length;
 log(" Indexed " + allFiles.length + " KB item(s), including " + lookupCount + " spreadsheet lookup row(s)");

 if (allFiles.length === 0) {
  return { text: "[No knowledge base documents found]", files: [], docsUsed: 0 };
 }

 var scoredFiles = [];
 var allowComparative = isComparisonQuery_(subject + " " + body);
 for (var i = 0; i < allFiles.length; i++) {
  if (isDisabledProductFile_(allFiles[i])) continue;
  if (!isSearchableKnowledgeFile_(allFiles[i])) continue;
  if (!allowComparative && isComparativeFile_(allFiles[i])) continue;
  var score = scoreKnowledgeFile_(allFiles[i], keywords, classification);
  scoredFiles.push({ file: allFiles[i], score: score });
 }

 var matchedFiles = scoredFiles
  .filter(function(f) { return f.score > 0; })
  .sort(function(a, b) { return b.score - a.score; })
  .slice(0, CONFIG.MAX_FILES_TO_SEARCH)
  .map(function(f) { return f.file; });

 log(" Matched " + matchedFiles.length + " file(s) by classifier scoring");

 if (matchedFiles.length === 0) {
  log(" No keyword matches falling back to FAQ, Pricelist, and DataSheet content");
  matchedFiles = allFiles
   .filter(function(file) {
    if (isDisabledProductFile_(file)) return false;
    var haystack = normalizeExclusionName_([file.name, file.category, file.path].join(" "));
    return containsAnyText_(haystack, ["faq", "pricelist", "price list", "datasheet", "data sheet"]);
   })
   .slice(0, CONFIG.MAX_FILES_TO_SEARCH);
 }

 if (matchedFiles.length === 0) {
  return { text: "[No matching knowledge base documents found]", files: [], docsUsed: 0 };
 }

 var aggregatedText = "";
 var docsUsed = 0;
 var filesToExtract = matchedFiles.slice(0, CONFIG.MAX_FILES_TO_EXTRACT);
 var fileNamesUsed = [];

 log(" Extracting top " + filesToExtract.length + " file(s) after classification scoring");
 for (var j = 0; j < filesToExtract.length; j++) {
  var fileMeta = filesToExtract[j];
  var content = extractFileContentByMetadata_(fileMeta);
  if (content && content.trim().length > 0) {
   aggregatedText += "\n=== Document: " + fileMeta.name + " ===\n"
    + "Original link: " + fileMeta.url + "\n"
    + content + "\n";
   docsUsed++;
   fileNamesUsed.push(fileMeta.name);
  }
 }

 if (classification.category === "Pricing" || isPricingQuery(keywords, emailText)) {
  var pricingData = getPricingData();
  if (pricingData.length > 0) {
   aggregatedText += pricingData;
   docsUsed++;
   fileNamesUsed.push("MASTER PRICELIST");
   log(" Pricing data appended to context");
  }
 }

 if (isProcessorCompatibilityQuery_(emailText)) {
  aggregatedText += getProcessorCompatibilityContext_();
  docsUsed++;
  fileNamesUsed.push("Processor Compatibility Chart");
  log("Processor compatibility chart appended to context");
 }

 if (isWipeDataVsRapidPurgeQuery_(emailText)) {
  aggregatedText += getWipeDataVsRapidPurgeContext_();
  docsUsed++;
  fileNamesUsed.push("Wipe Data vs Rapid Purge Technical Distinction");
  log("Wipe Data vs Rapid Purge context appended to context");
 }

 if (isGuardPackageSeriesQuery_(emailText)) {
  aggregatedText += getGuardPackageSeriesContext_(emailText);
  docsUsed++;
  fileNamesUsed.push("Guard Package Series Feature Matrix");
  log("Guard Package Series matrix appended to context");
 }

 if (isGeneralDefinitionQuery_(emailText)) {
  aggregatedText += getGeneralExplanationContext_(emailText);
  docsUsed++;
  fileNamesUsed.push("General Product Explanation Glossary");
  log("General explanation glossary appended to context");
 }

 return {
  text: aggregatedText || "[Could not extract text from knowledge base documents]",
  files: matchedFiles,
  docsUsed: docsUsed,
  filesUsed: fileNamesUsed.join("; "),
  classification: classification,
 };
}

function scoreKnowledgeFile_(fileMeta, keywords, classification) {
 var haystack = normalizeProductPhrases_(String(fileMeta.name || "") + " " + String(fileMeta.category || "") + " " + String(fileMeta.productLine || "") + " " + String(fileMeta.topic || "") + " " + String(fileMeta.path || "") + " " + String(fileMeta.aiNotes || "") + " " + getFolderTextForFile_(fileMeta));
 var score = 0;
 if (fileMeta.sourceType === "kb_lookup_index") score += getKnowledgeLookupBoost_(fileMeta);
 for (var k = 0; k < keywords.length; k++) {
  if (haystack.indexOf(normalizeProductPhrases_(keywords[k])) >= 0) score += 2;
 }

 if (classification && classification.productLine && classification.productLine !== "General X-PHY") {
  if (haystack.indexOf(normalizeProductPhrases_(classification.productLine)) >= 0) score += 12;
  for (var i = 0; i < (classification.strongTerms || []).length; i++) {
   if (haystack.indexOf(classification.strongTerms[i]) >= 0) score += 10;
  }
  for (var w = 0; w < (classification.weakTerms || []).length; w++) {
   if (haystack.indexOf(classification.weakTerms[w]) >= 0) score += 2;
  }
 }

 if (classification) {
  var category = classification.category;
  if (category === "Pricing" && containsAnyText_(haystack, ["price", "pricing", "pricelist", "quote"])) score += 15;
  if (category === "Installation" && containsAnyText_(haystack, ["install", "installation", "setup", "integration", "guide", "manual"])) score += 12;
  if (category === "Compatibility" && containsAnyText_(haystack, ["compatibility", "requirement", "processor", "cpu", "notebook"])) score += 12;
  if (category === "Technical Support" && containsAnyText_(haystack, ["support", "faq", "guide", "troubleshoot"])) score += 10;
  if (category === "Demo / Trial" && containsAnyText_(haystack, ["demo", "trial", "setup", "guide"])) score += 8;
 }

 if (containsAnyText_(haystack, ["faq", "datasheet", "data sheet", "user guide", "guide"])) score += 2;
 // FAQ/knowledgebase docs are the broadest single source for multi-part or
 // technical emails; make sure a product-matched FAQ can compete with narrow
 // guides and aiNotes-boosted rows. This haystack keeps punctuation, so the
 // dotted "f.a.q" spelling must be matched explicitly.
 if (containsAnyText_(haystack, ["faq", "f.a.q", "knowledgebase", "knowledge base"])) score += 8;
 if (fileMeta.priority) score += Math.max(0, 10 - Math.min(Number(fileMeta.priority), 100) / 10);
 return score;
}

function getKnowledgeLookupBoost_(fileMeta) {
 var aiNotes = String(fileMeta.aiNotes || "").trim();
 if (aiNotes.length >= 20) return 25;
 if (String(fileMeta.topic || "").trim() || String(fileMeta.linkLabel || "").trim()) return 12;
 return 4;
}

function isSearchableKnowledgeFile_(fileMeta) {
 if (fileMeta.sourceType === "kb_lookup_index") return true;
 var typeText = normalizeExclusionName_(String(fileMeta.inventoryType || "") + " " + String(fileMeta.mimeType || "") + " " + String(fileMeta.name || ""));
 if (typeText.indexOf("video") >= 0 || typeText.indexOf("mp4") >= 0 || typeText.indexOf("zip") >= 0 || typeText.indexOf("installer") >= 0) return false;
 if (fileMeta.mimeType === "application/octet-stream") return false;
 return true;
}

function isDisabledProductFile_(fileMeta) {
 if (CONFIG.SERVER_DEFENDER_ENABLED) return false;
 var haystack = normalizeProductPhrases_(String(fileMeta.name || "") + " " + String(fileMeta.category || "") + " " + String(fileMeta.productLine || "") + " " + String(fileMeta.path || "") + " " + getFolderTextForFile_(fileMeta));
 return haystack.indexOf("server_defender") >= 0;
}


