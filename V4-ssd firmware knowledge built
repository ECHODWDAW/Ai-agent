function wordsShareStem_(a, b) {
 var len = Math.min(a.length, b.length, 6);
 if (len < 4) return a === b;
 return a.slice(0, len) === b.slice(0, len);
}

function limitButtonsWithFinalAction_(buttons, finalActionButton, maxButtons, customerText) {
 maxButtons = maxButtons || 3;
 var output = uniqueButtons_(buttons || []);
 if (finalActionButton && finalActionButton.url) {
  output = output.filter(function(button) {
   return button && button.url !== finalActionButton.url;
  });
 }

 var finalCount = (finalActionButton && finalActionButton.url) ? 1 : 0;
 if (output.length + finalCount <= maxButtons) {
  return finalCount ? uniqueButtons_(output.concat([finalActionButton])) : output;
 }

 var text = String(customerText || "").toLowerCase();
 var textWords = text.split(/\s+/).filter(function(w) { return w.length > 2; });
 var ranked = output.map(function(button) {
  var labelWords = String(button.label || "").toLowerCase().split(/\s+/).filter(function(w) { return w.length > 2; });
  var score = 0;
  for (var i = 0; i < labelWords.length; i++) {
   for (var j = 0; j < textWords.length; j++) {
    if (wordsShareStem_(labelWords[i], textWords[j])) { score++; break; }
   }
  }
  return { button: button, score: score };
 }).sort(function(a, b) { return b.score - a.score; })
  .map(function(item) { return item.button; });

 var keep = Math.max(0, maxButtons - finalCount);
 var kept = ranked.slice(0, keep);
 return finalCount ? uniqueButtons_(kept.concat([finalActionButton])) : kept;
}

