}

function extractTablesForShortening_(html) {
 var tables = [];
 var replaced = String(html || "").replace(/<table\b[\s\S]*?<\/table>/gi, function(tableHtml) {
  tables.push(tableHtml);
  return "[[TABLE_" + tables.length + "]]";
 });
 return { html: replaced, tables: tables };
}

function restoreExtractedTables_(html, tables) {
 var out = String(html || "");
 tables = tables || [];
 for (var i = 0; i < tables.length; i++) {
  var token = "[[TABLE_" + (i + 1) + "]]";
  if (out.indexOf(token) >= 0) {
   out = out.replace(token, tables[i]);
   continue;
  }

  // If the shortener drops a placeholder, restore the protected table before
  // the pricing footer or sign-off so product data never lands after Ethan's
  // signature and is never silently lost.
  var insertionIndex = out.search(/All prices (?:are|are quoted)|(?:Best regards|Kind regards|Warm regards|Regards|Sincerely|Cheers),?/i);
  if (insertionIndex >= 0) {
   out = out.substring(0, insertionIndex) + tables[i] + "<br><br>" + out.substring(insertionIndex);
  } else {
   out += "<br><br>" + tables[i];
  }
 }
 return out;
}

function shortenClaudeReply_(modelId, replyHtml, targetChars, logMeta) {
 var targetWords = targetChars > 1300 ? 180 : (targetChars > 1000 ? 150 : 120);
 var shortenPrompt = "Shorten this customer support email reply while preserving the greeting, important facts, useful links, and sign-off.\n"
  + "Rules:\n"
  + "- Return clean HTML only.\n"
  + "- One greeting, then the answer, then the sign-off.\n"
  + "- Use one short paragraph for one topic. For multiple distinct products/topics, keep one short paragraph per product/topic.\n"
  + "- Maximum " + targetWords + " words before the sign-off.\n"
  + "- No headings, no button-style links.\n"
  + "- Preserve any [[TABLE_n]] placeholder tokens exactly as written, in their original position. Never delete, move, merge, or rewrite them - they are protected pricing tables that will be reinserted after you finish.\n\n"
  + "REPLY TO SHORTEN:\n" + replyHtml;

 var payload = {
  model: modelId,
  max_tokens: CONFIG.CLAUDE_SHORTEN_MAX_TOKENS,
  temperature: 0,
  system: "You rewrite customer support emails to be concise without changing factual meaning.",
  messages: [{ role: "user", content: shortenPrompt }],
 };

 var response = UrlFetchApp.fetch("https://api.anthropic.com/v1/messages", {
  method: "post",
  contentType: "application/json",
  headers: {
   "x-api-key": CONFIG.CLAUDE_API_KEY,
   "anthropic-version": "2023-06-01",
  },
  payload: JSON.stringify(payload),
  muteHttpExceptions: true,
 });

 if (response.getResponseCode() !== 200) {
  log(" Shorten pass failed; using original reply");
  return replyHtml;
 }

 var responseBody = JSON.parse(response.getContentText());
 var shortened = "";
 for (var i = 0; i < responseBody.content.length; i++) {
  if (responseBody.content[i].type === "text") shortened += responseBody.content[i].text;
 }

 logClaudeTokenUsage_({
  operation: "shorten",
  model: modelId,
  sender: logMeta && logMeta.sender,
  subject: logMeta && logMeta.subject,
  usage: responseBody.usage,
  responseChars: shortened.length,
 });

  shortened = postProcessAiReply_(shortened, logMeta && logMeta.subject, "", logMeta && logMeta.senderName);
 return shortened || replyHtml;
}

function getClaudeMaxTokensForRequest_(subject, body) {
 var queryText = ((subject || "") + " " + (body || "")).toLowerCase();
 if (containsAnyText_(queryText, PRICING_KEYWORDS)) {
  // Pricing tables need more output room than ordinary short replies. Keep
  // the global default unchanged for every other request.
  return Math.max(CONFIG.CLAUDE_MAX_TOKENS, 1400);
 }
 return CONFIG.CLAUDE_MAX_TOKENS;
}

function callClaude(sender, senderName, subject, body, knowledgeContext) {
 LAST_CLAUDE_MODEL_USED_ = "";
 var customerIntentText = getBodyPreferredIntentText_(subject, body);
 var definitionInstruction = isGeneralDefinitionQuery_(customerIntentText)
  ? "\nThis appears to be a basic definition question. Explain the general concept first in simple terms, then add one short sentence on how it relates to X-PHY if relevant. Do not lead with a full X-PHY product pitch.\n"
  : "";
 var curiosityInstruction = isProductInfoQuestion_(customerIntentText)
  && !isGuidedUseRequestText_(customerIntentText)
  && !isSupportRequestText_(customerIntentText)
  ? "\nThis is a product curiosity question only. Keep the answer to one brief overview paragraph. Do not include setup, installation, guide, troubleshooting, or support-page details unless the customer explicitly asked for them.\n"
  : "";
 var mixedIntentInstruction = isProductInfoQuestion_(customerIntentText)
  && (isGuidedUseRequestText_(customerIntentText) || isSupportRequestText_(customerIntentText))
  ? "\nThis is a mixed-intent email. Treat each product separately. For products the customer is only curious about, give a brief overview only and do not include requirements, setup steps, guides, support pages, or troubleshooting. For products the customer specifically asks to install, configure, or get help with, answer that setup/support request directly.\n"
  : "";
 var pricingInstruction = containsAnyText_(customerIntentText.toLowerCase(), PRICING_KEYWORDS)
  ? "\nPRICING OUTPUT REQUIREMENT: Emit plain, unstyled <table><tr><td> markup; the script applies all styling later. For capacity variants, use one capacity per column, a capacity header row, and one row per tier. Format each value as '<Tier>: <Part Number> / $<Price>'. Include every requested tier, including Premium, even if the intro must be shortened. Close every <tr> and </table> before the sign-off. For one-dimensional pricing, use one column with one '<Label>: <Part Number> / $<Price>' row per option and no header. A single quoted price may remain in prose.\n"
  : "";
 var productIntentInstruction = buildProductSpecificReplyInstruction_(customerIntentText);
 var userPrompt = "CUSTOMER EMAIL:\n"
  + "From: " + sender + "\n"
  + "Customer's name: " + senderName + "\n"
  + "Subject: " + subject + "\n"
  + "Body:\n" + body + "\n\n"
  + "KNOWLEDGE BASE CONTEXT:\n" + knowledgeContext + "\n\n"
  + definitionInstruction
  + curiosityInstruction
  + mixedIntentInstruction
  + pricingInstruction
  + productIntentInstruction
  + "Please draft a concise reply to this customer's email in HTML format using the knowledge base context above. For one topic, keep it to one short paragraph before the sign-off. For multiple distinct products or topics, use one short paragraph per product/topic before the sign-off.";

 var models = [
  { id: CONFIG.CLAUDE_MODEL, name: "Primary", retries: 3 },
  { id: CONFIG.CLAUDE_FALLBACK_MODEL, name: "Fallback", retries: 3 },
 ];
 var maxTokensForRequest = getClaudeMaxTokensForRequest_(subject, body);

 for (var m = 0; m < models.length; m++) {
  var model = models[m];
  log(" Trying " + model.name + "...");

  var payload = {
   model: model.id,
   max_tokens: maxTokensForRequest,
   temperature: CONFIG.CLAUDE_TEMPERATURE,
   system: getSystemPrompt_(),
   messages: [{ role: "user", content: userPrompt }],
  };

  var options = {
   method: "post",
   contentType: "application/json",
   headers: {
    "x-api-key": CONFIG.CLAUDE_API_KEY,
    "anthropic-version": "2023-06-01",
   },
   payload: JSON.stringify(payload),
   muteHttpExceptions: true,
  };

  for (var attempt = 1; attempt <= model.retries; attempt++) {
   var response = UrlFetchApp.fetch("https://api.anthropic.com/v1/messages", options);
   var statusCode = response.getResponseCode();
   var responseText = response.getContentText();
   var responseBody;
   try {
    responseBody = JSON.parse(responseText);
   } catch (parseError) {
    responseBody = { error: { message: responseText.substring(0, 500) } };
   }

   if (statusCode === 200) {
    var replyText = "";
    for (var i = 0; i < responseBody.content.length; i++) {
     if (responseBody.content[i].type === "text") {
      replyText += responseBody.content[i].text;
     }
    }

    // Bill-time accounting: tokens are spent the moment the API responds,
    // so log them before any step that could still fail.
    logClaudeTokenUsage_({
     operation: "reply",
     model: model.id,
     sender: sender,
     subject: subject,
     usage: responseBody.usage,
     responseChars: (replyText || "").length,
    });

    if (!replyText || replyText.trim().length === 0) {
     log(" " + model.name + " returned an empty response; processEmail will use the empty-reply guard");
     LAST_CLAUDE_MODEL_USED_ = model.id;
     return "";
    }

    replyText = postProcessAiReply_(replyText, subject, body, senderName);
    LAST_CLAUDE_MODEL_USED_ = model.id;
    var adaptiveLimit = getAdaptiveReplyLimit_(subject, body, knowledgeContext);
    var tableExtraction = extractTablesForShortening_(replyText);
    if (tableExtraction.html.length > adaptiveLimit) {
     log(" " + model.name + " prose is " + tableExtraction.html.length + " characters (tables excluded); adaptive limit is " + adaptiveLimit + "; shortening prose only...");
     var shortenedProse = shortenClaudeReply_(model.id, tableExtraction.html, adaptiveLimit, {
      sender: sender,
      senderName: senderName,
      subject: subject,
     });
     replyText = restoreExtractedTables_(shortenedProse, tableExtraction.tables);
    }

    // Token usage already logged at response time (bill-time accounting).

    log(" " + model.name + " generated " + replyText.length + " characters after cleanup");
    return replyText;
   }

   var lastError = (responseBody.error && responseBody.error.message) || ("HTTP " + statusCode);

   if (isRetryableHttpStatus_(statusCode)) {
    var waitTime = Math.min(10 * Math.pow(2, attempt - 1), 30);
    log(" " + model.name + " attempt " + attempt + "/" + model.retries + " " + lastError + ". Waiting " + waitTime + "s...");
    Utilities.sleep(waitTime * 1000);
    continue;
   }

   if (m < models.length - 1) {
    log(" " + model.name + " failed: " + lastError + " trying next model...");
    break;
   }

   throw new Error("Claude API error: " + lastError);
  }
 }

 throw new Error("All models failed after retries. Anthropic API may be experiencing an outage.");
}

function isRetryableHttpStatus_(statusCode) {
 return [408, 429, 500, 502, 503, 504, 529].indexOf(statusCode) >= 0;
}


