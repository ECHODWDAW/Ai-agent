 if (!isInstallIntent && !isSupportIntent && !isCompatibilityIntent) return buttons;
 for (var i = 0; i < intents.length; i++) {
  var productLine = intents[i].label;
  var productInstallIntent = isInstallIntent && isGuidedUseIntentForProduct_(productLine, text);
  var productSupportIntent = isSupportIntent && isSupportIntentForProduct_(productLine, text);
  var docs = SUPPORT_DOCUMENTATION_LINKS[productLine];
  if (isCompatibilityIntent && docs && docs.compatibility) buttons.push(docs.compatibility);
  if (!productInstallIntent && !productSupportIntent) continue;
  if (!docs) continue;
  if (productLine === "Secure SSD" && productInstallIntent) {
   buttons.push(docs.installGuide);
  } else if (productLine === "Deepfake Detector" && productInstallIntent) {
   buttons.push(docs.guide);
  } else if (productLine === "Guard PC Application") {
   buttons.push(docs.guide);
  } else {
   var inventoryButton = getBestInventoryDocumentationButton_(productLine, productInstallIntent, productSupportIntent, text);
   if (inventoryButton) buttons.push(inventoryButton);
  }
 }
 return buttons;
}

function buildSupportDocumentationButtons_(productLine, isInstallIntent, isSupportIntent, text, isCompatibilityIntent) {
 var docs = SUPPORT_DOCUMENTATION_LINKS[productLine] || SUPPORT_DOCUMENTATION_LINKS["General X-PHY"];
 var buttons = [];
 if (!isInstallIntent && !isSupportIntent && !isCompatibilityIntent) return buttons;
 var inventoryButtons = buildInventoryDocumentationButtons_(productLine, isInstallIntent, isSupportIntent || isCompatibilityIntent, text);

 if (productLine === "Secure SSD") {
  if (isSupportIntent) buttons.push(docs.support);
  if (isInstallIntent) buttons.push(docs.installGuide, docs.installVideo);
 } else if (productLine === "Guard PC Application") {
  if (isSupportIntent) buttons.push(docs.support);
  buttons.push(docs.guide);
  if (isInstallIntent) buttons.push(docs.installVideo);
  if (containsAnyText_(text, ["configuration", "configure", "settings", "setting"])) buttons.push(docs.configVideo);
 } else if (productLine === "Deepfake Detector") {
  if (isSupportIntent) buttons.push(docs.support);
  if (isInstallIntent) buttons.push(docs.guide);
 } else {
  if (isSupportIntent) buttons.push(docs.support);
 }
 if (isCompatibilityIntent && docs.compatibility) buttons.push(docs.compatibility);
 return uniqueButtons_(inventoryButtons.concat(buttons));
}

function getSupportButtonForProduct_(productLine) {
 var docs = SUPPORT_DOCUMENTATION_LINKS[productLine] || SUPPORT_DOCUMENTATION_LINKS["General X-PHY"];
 return docs.support || SUPPORT_DOCUMENTATION_LINKS["General X-PHY"].support;
}

function getSupportButtonForDetectedNeed_(intents, primaryIntent, text, isMultiTopic) {
 if (isMultiTopic) {
  for (var i = 0; i < intents.length; i++) {
   if (isGuidedUseIntentForProduct_(intents[i].label, text) || isSupportIntentForProduct_(intents[i].label, text)) {
    return getSupportButtonForProduct_(intents[i].label);
   }
  }
 }
 return getSupportButtonForCustomerNeed_(primaryIntent.label, text, false);
}

function isProductInfoIntentForProduct_(productLine, text) {
 text = String(text || "").toLowerCase();
 var terms = ["tell me more", "more about", "learn more", "what is", "what does", "how does", "overview", "information", "details", "explain"];
 if (!containsAnyText_(text, terms)) return false;
 return isProductMentionedNearAnyTerm_(productLine, text, terms, 90);
}

function isSalesIntentForProduct_(productLine, text) {
 text = String(text || "").toLowerCase();
 if (!containsAnyText_(text, ["price", "pricing", "cost", "quote", "quotation", "how much", "sales", "buy", "purchase", "order", "available", "availability"])) return false;
 return isProductMentionedNearAnyTerm_(productLine, text, ["price", "pricing", "cost", "quote", "quotation", "how much", "sales", "buy", "purchase", "order", "available", "availability"], 90);
}

function isGuidedUseIntentForProduct_(productLine, text) {
 text = String(text || "").toLowerCase();
 if (!isGuidedUseRequestText_(text)) return false;
 return isProductMentionedNearAnyTerm_(productLine, text, ["install", "installation", "setup", "set up", "integrate", "integration", "configure", "configuration", "settings", "guide", "manual", "how do i use", "how to use"], 90);
}

function isSupportIntentForProduct_(productLine, text) {
 text = String(text || "").toLowerCase();
 if (!isSupportRequestText_(text)) return false;
 return isProductMentionedNearAnyTerm_(productLine, text, ["support", "issue", "problem", "error", "not working", "failed", "troubleshoot", "fix", "cannot", "can't", "unable"], 90);
}

function isProductMentionedNearAnyTerm_(productLine, text, terms, distance) {
 var aliases = getProductIntentAliases_(productLine);
 if (aliases.length === 0) return false;
 var clauses = splitCustomerIntentClauses_(text);
 for (var c = 0; c < clauses.length; c++) {
  var clause = clauses[c];
  var hasProduct = false;
  for (var a = 0; a < aliases.length; a++) {
   if (clause.indexOf(aliases[a]) >= 0) {
    hasProduct = true;
    break;
   }
  }
  if (!hasProduct) continue;
  for (var t = 0; t < terms.length; t++) {
   if (clause.indexOf(terms[t]) >= 0) return true;
  }
 }
 return false;
}

function splitCustomerIntentClauses_(text) {
 return String(text || "")
  .toLowerCase()
  .replace(/\b(?:and|also|plus)\b/g, "|")
  .split(/[|,;.!?]+/)
  .map(function(part) { return part.replace(/\s+/g, " ").trim(); })
  .filter(function(part) { return part.length > 0; });
}

function getProductIntentAliases_(productLine) {
 if (productLine === "Secure SSD") return ["secure ssd", "cyber secure ssd", "ssd", "nvme"];
 if (productLine === "Deepfake Detector") return ["deepfake detector", "deep fake detector", "deepfake", "deep fake", "dfd"];
 if (productLine === "Guard PC Application") return ["guard pc", "guard application", "guard pc application"];
 if (productLine === "Server Defender") return ["server defender"];
 if (productLine === "Management Console") return ["management console"];
 return [];
}

function getBodyPreferredIntentText_(subject, body) {
 var bodyText = String(body || "").toLowerCase();
 if (detectCustomerProductIntents_(bodyText).length > 0) return bodyText;
 return (bodyText + " " + String(subject || "")).toLowerCase();
}

function getSupportButtonForCustomerNeed_(productLine, text, isMultiTopic) {
 if (isMultiTopic) return SUPPORT_DOCUMENTATION_LINKS["Secure SSD"].support;
 if (productLine === "Secure SSD" || productLine === "Guard PC Application") return SUPPORT_DOCUMENTATION_LINKS["Secure SSD"].support;
 if (productLine === "Deepfake Detector") return SUPPORT_DOCUMENTATION_LINKS["Deepfake Detector"].support;
 if (containsAnyText_(text, ["endpoint", "ssd", "guard", "pc application", "not working", "something went wrong", "how to", "setup", "install"])) {
  return SUPPORT_DOCUMENTATION_LINKS["Secure SSD"].support;
 }
 return getSupportButtonForProduct_(productLine);
}

function getBestInventoryDocumentationButton_(productLine, isInstallIntent, isSupportIntent, text) {
 var buttons = buildInventoryDocumentationButtons_(productLine, isInstallIntent, isSupportIntent, text);
 return buttons.length > 0 ? buttons[0] : null;
}

function buildInventoryDocumentationButtons_(productLine, isInstallIntent, isSupportIntent, text) {
 var inventory = getDocumentInventoryIndex_();
 if (inventory.length === 0) return [];

 var allowComparative = isComparisonQuery_(text);
 var scored = [];
 for (var i = 0; i < inventory.length; i++) {
  var row = inventory[i];
  if (!row.url || !isInventoryRowForProduct_(row, productLine)) continue;
  if (!allowComparative && isComparativeFile_(row)) continue;

  var score = scoreInventoryButtonCandidate_(row, isInstallIntent, isSupportIntent, text);
  if (score > 0) scored.push({ row: row, score: score });
 }

 return scored
  .sort(function(a, b) { return b.score - a.score; })
  .slice(0, 2)
  .map(function(item) { return inventoryRowToButton_(item.row, productLine); });
}

function isInventoryRowForProduct_(row, productLine) {
 if (!productLine || productLine === "General X-PHY") return false;
 if (row.productLine === productLine) return true;
 var target = normalizeExclusionName_(productLine);
 var haystack = normalizeExclusionName_([row.productLine, row.category, row.name, row.path].join(" "));
 if (target === "secure ssd") return haystack.indexOf("ssd") >= 0 || haystack.indexOf("endpoint solution") >= 0;
 if (target === "deepfake detector") return haystack.indexOf("deepfake") >= 0 || haystack.indexOf("dfd") >= 0;
 if (target === "guard pc application") return haystack.indexOf("guard pc") >= 0 || haystack.indexOf("guard application") >= 0;
 return haystack.indexOf(target) >= 0;
}

function scoreInventoryButtonCandidate_(row, isInstallIntent, isSupportIntent, text) {
 var haystack = normalizeExclusionName_([row.name, row.category, row.productLine, row.inventoryType, row.path].join(" "));
 var score = 0;
 var wantsConfig = containsAnyText_(text, ["configuration", "configure", "settings", "setting"]);
 var wantsCompatibility = containsAnyText_(text, ["compatibility", "compatible", "requirement", "processor", "cpu", "notebook", "laptop"]);
 var wantsDemo = containsAnyText_(text, ["demo", "demonstration", "video", "trial"]);

 if (isInstallIntent && containsAnyText_(haystack, ["install", "installation", "setup", "integration", "user guide", "guide", "manual", "partition"])) score += 30;
 if (isSupportIntent && containsAnyText_(haystack, ["support", "faq", "knowledgebase", "user guide", "guide", "manual"])) score += 20;
 if (wantsConfig && containsAnyText_(haystack, ["configuration", "configurations", "settings"])) score += 30;
 if (wantsCompatibility && containsAnyText_(haystack, ["compatibility", "notebook", "requirement", "datasheet", "data sheet"])) score += 30;
 if (wantsDemo && containsAnyText_(haystack, ["demo", "demonstration", "video"])) score += 25;

 if (containsAnyText_(haystack, ["pdf", "google doc", "user guide", "guide"])) score += 8;
 if (containsAnyText_(haystack, ["video", "mp4"])) score += wantsDemo ? 12 : 3;
 if (containsAnyText_(haystack, ["datasheet", "data sheet"])) score += wantsCompatibility ? 12 : 2;
 return score;
}

function inventoryRowToButton_(row, productLine) {
 return {
  label: buildInventoryButtonLabel_(row, productLine),
  url: row.url,
 };
}

function buildInventoryButtonLabel_(row, productLine) {
 var haystack = normalizeExclusionName_([row.name, row.category, row.inventoryType].join(" "));
 var prefix = getProductButtonPrefix_(productLine);
 if (haystack.indexOf("video") >= 0 || haystack.indexOf("mp4") >= 0) return prefix + " Video";
 if (haystack.indexOf("compatibility") >= 0 || haystack.indexOf("notebook") >= 0) return prefix + " Compatibility";
 if (haystack.indexOf("datasheet") >= 0 || haystack.indexOf("data sheet") >= 0) return prefix + " Datasheet";
 if (haystack.indexOf("faq") >= 0 || haystack.indexOf("knowledgebase") >= 0) return prefix + " FAQ";
 if (haystack.indexOf("install") >= 0 || haystack.indexOf("setup") >= 0 || haystack.indexOf("integration") >= 0) return prefix + " Install Guide";
 return prefix + " Guide";
}

function getProductButtonPrefix_(productLine) {
 if (productLine === "Secure SSD") return "SSD";
 if (productLine === "Deepfake Detector") return "DFD";
 if (productLine === "Guard PC Application") return "Guard PC";
 if (productLine === "Management Console") return "MC";
 return productLine || "X-PHY";
}

