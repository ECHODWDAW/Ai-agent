function normalizePromptRuleKey_(section, rule) {
 section = String(section || "").toLowerCase().trim().replace(/\s+/g, " ");
 rule = String(rule || "").toLowerCase().trim().replace(/\s+/g, " ");
 if (!rule) return "";
 return section + "||" + rule;
}

