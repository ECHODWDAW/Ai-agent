function buildProductSpecificReplyInstruction_(text) {
 text = String(text || "").toLowerCase();
 var intents = detectCustomerProductIntents_(text);
 if (intents.length === 0) return "";

 var lines = [];
 for (var i = 0; i < intents.length; i++) {
  var productLine = intents[i].label;
  if (productLine === "General X-PHY") continue;

  var wantsInfo = isProductInfoIntentForProduct_(productLine, text);
  var wantsInstall = isGuidedUseIntentForProduct_(productLine, text);
  var wantsSupport = isSupportIntentForProduct_(productLine, text);

  if (wantsInstall || wantsSupport) {
   lines.push("- " + productLine + ": answer only the requested install/setup/support question for this product.");
  } else if (wantsInfo) {
   lines.push("- " + productLine + ": curiosity/overview only. Give a short explanation of what it is or does. Do not include installation steps, setup walkthroughs, requirements, guide links, support-page wording, or detection/runtime details for this product.");
  }
 }

 if (lines.length === 0) return "";
 return "\nPRODUCT-SPECIFIC INTENT LOCK:\n"
  + lines.join("\n")
  + "\nFollow this product-specific intent lock even if the knowledge base context contains setup or guide text for another product.\n";
}

