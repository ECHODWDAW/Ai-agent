    + getCriticalPromptOverrides_();
  }
  return "You are a helpful and professional customer support agent for " + CONFIG.COMPANY_NAME + ".\n"
   + CONFIG.COMPANY_DESCRIPTION + "\n\n"
   + editablePrompt + "\n\n"
   + getCriticalPromptOverrides_();
 }

 return SYSTEM_PROMPT + "\n\n" + getCriticalPromptOverrides_();
}

function isEditablePromptTooThin_(editablePrompt) {
 var prompt = String(editablePrompt || "");
 var lower = prompt.toLowerCase();
 if (prompt.length < 3000) return true;
 if (lower.indexOf("format rules") < 0 && lower.indexOf("format") < 0) return true;
 if (lower.indexOf("bold") < 0 && prompt.indexOf("<b>") < 0) return true;
 return false;
}

