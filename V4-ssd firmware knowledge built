function isPureProductOverviewQuery_(text, productLine) {
 text = String(text || "").toLowerCase();
 if (!productLine || !PRODUCT_OVERVIEW_TEXT_[productLine]) return false;
 if (!isProductInfoQuestion_(text)) return false;

 // Don't let the generic overview shortcut swallow emails that have their
 // own curated technical context (e.g. Wipe Data vs Rapid Purge) or that
 // ask multiple distinct numbered/technical questions in one email. Those
 // need real knowledge base search, not a one-paragraph product blurb.
 if (isWipeDataVsRapidPurgeQuery_(text)) return false;
 if (isGuardPackageSeriesQuery_(text)) return false;
 if (detectCustomerProductIntents_(text).length > 1) return false;
 if (isMultiQuestionEmail_(text)) return false;

 return !isGuidedUseRequestText_(text)
  && !isSupportRequestText_(text)
  && !containsAnyText_(text, [
   "requirement", "requirements", "specification", "specifications", "specs",
