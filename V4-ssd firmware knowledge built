 var exactSet = getExcludeExactNameSet_();
 if (exactSet[key]) return true;

 for (var i = 0; i < EXCLUDE_NAME_PATTERNS.length; i++) {
  var pattern = normalizeExclusionName_(EXCLUDE_NAME_PATTERNS[i]);
  if (!pattern) continue;
  if (CONFIG.INCLUDE_SCREENSHOT_FOLDERS_FOR_IMAGES && isFolder && isScreenshotFolderName_(pattern)) {
   continue;
