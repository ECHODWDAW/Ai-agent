  } else {
   GmailApp.createDraft(recipientLists.to.join(","), makeReplySubject_(subject), replyOptions.body || "", replyOptions);
  }
  status = "DRAFT_DISABLED_PRODUCT";
  log("Disabled product draft created for " + classification.productLine);
 }

 logToSheet({
  timestamp: new Date(),
  sender: sender,
