// ============================================================================
// SECTION 14B: SHAREABLE DB SYNC AND INDEX
// Copies the [R]-filtered shareable inventory into Ethan's config spreadsheet
// and serves it as the knowledge base index.
// ============================================================================

function syncShareableDbToEthanConfig_() {
 loadSavedConfigSpreadsheetId_();
 if (!CONFIG.CONFIG_SPREADSHEET_ID) throw new Error("Run setupEditableConfigTemplate_() first, or set CONFIG_SPREADSHEET_ID.");
 if (!CONFIG.SHAREABLE_DB_SOURCE_SPREADSHEET_ID) throw new Error("Set CONFIG.SHAREABLE_DB_SOURCE_SPREADSHEET_ID to the inventory workbook ID.");

 var config = SpreadsheetApp.openById(CONFIG.CONFIG_SPREADSHEET_ID);
 ensureShareableDbSheet_(config);

 var source = SpreadsheetApp.openById(CONFIG.SHAREABLE_DB_SOURCE_SPREADSHEET_ID);
 var sourceSheet = source.getSheetByName(CONFIG.SHAREABLE_DB_SOURCE_SHEET_NAME);
 if (!sourceSheet) throw new Error('Source sheet "' + CONFIG.SHAREABLE_DB_SOURCE_SHEET_NAME + '" not found in the inventory workbook.');

 var values = sourceSheet.getDataRange().getValues();
 if (values.length < 2) throw new Error("Source shareable inventory has no data rows. Run crawlXPhyDatabase() in the inventory workbook first.");

 var headers = values[0];
 var headerMap = buildInventoryHeaderMap_(headers);
 var pathIndex = headerMap["path"];
 var nameIndex = headerMap["name"];

 var kept = [];
 var skipped = 0;
 for (var i = 1; i < values.length; i++) {
  var row = values[i];
  var path = pathIndex !== undefined ? String(row[pathIndex] || "") : "";
  var name = nameIndex !== undefined ? String(row[nameIndex] || "") : "";

  // Safety net: re-apply the restricted marker rule even though the source
  // tab is already the shareable (filtered) inventory.
  if (hasRestrictedMarker_(name) || hasRestrictedMarker_(path)) {
   skipped++;
   continue;
  }
  kept.push(row);
 }

 var sheet = config.getSheetByName(CONFIG.SHAREABLE_DB_SHEET_NAME) || config.insertSheet(CONFIG.SHAREABLE_DB_SHEET_NAME);
 sheet.clear();
 sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
 sheet.getRange(1, 1, 1, headers.length)
  .setFontWeight("bold")
  .setBackground("#2563EB")
  .setFontColor("#ffffff");
 sheet.setFrozenRows(1);
 if (kept.length > 0) {
  sheet.getRange(2, 1, kept.length, headers.length).setValues(kept);
 }
 try {
  var existingFilter = sheet.getFilter();
  if (existingFilter) existingFilter.remove();
  sheet.getRange(1, 1, Math.max(sheet.getLastRow(), 1), headers.length).createFilter();
 } catch (e) { }
 sheet.setTabColor("#2563EB");

 clearKnowledgeBaseCache_();
 log("SHAREABLE_DB synced: " + kept.length + " row(s) written, " + skipped + " restricted row(s) filtered out.");
}

