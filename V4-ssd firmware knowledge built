function insertLeadInBeforeSignOff_(html, leadInHtml) {
 if (!leadInHtml) return html;
 html = String(html || "");

 // Compare visible text so HTML tags and entities cannot hide a duplicate.
 var visibleHtml = stripHtmlTags_(html)
  .replace(/&nbsp;/gi, " ")
  .replace(/&amp;/gi, "&")
  .replace(/\s+/g, " ")
  .toLowerCase();
 var visibleLeadIn = stripHtmlTags_(leadInHtml)
  .replace(/&nbsp;/gi, " ")
  .replace(/&amp;/gi, "&")
  .replace(/\s+/g, " ")
  .trim()
  .toLowerCase();
 var duplicateFragment = visibleLeadIn.indexOf("feel free to contact our sales team") >= 0
  ? "feel free to contact our sales team"
  : visibleLeadIn;
 if (duplicateFragment && visibleHtml.indexOf(duplicateFragment) >= 0) return html;

 var insertion = "<br><br>" + leadInHtml + "<br><br>";
 var signOffPattern = /(?:<br\s*\/?>|\s)*(Best regards|Warm regards|Kind regards),?/i;
 var match = html.match(signOffPattern);
 if (match) {
  var index = html.indexOf(match[0]);
  var signOff = html.slice(index).replace(/^(?:<br\s*\/?>|\s)*/i, "");
  return html.slice(0, index) + insertion + signOff;
 }
 return html + insertion;
}

