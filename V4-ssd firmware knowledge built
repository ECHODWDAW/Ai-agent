 return "Hi " + escapeHtml_(name) + ",<br><br>"
  + "Thank you for your interest in <b>" + escapeHtml_(productLine) + "</b>. This product is currently still in development, and more details will be released at a later stage. We have forwarded your enquiry to our team, and we will reach out to learn more about your requirements.<br><br>"
  + CONFIG.SUPPORT_SIGN_OFF;
}

function sendTemporarilyUnavailableProductReply_(thread, message, sender, senderName, subject, body, toRecipients, ccRecipients, classification) {
 thread.markRead();
 applyLabel(thread, CONFIG.PROCESSED_LABEL);

 classification.escalationReason = classification.productLine + " is temporarily disabled in the AI agent";
 forwardToHuman_(message, classification.escalationReason);

 var aiReply = buildTemporarilyUnavailableProductReply_(senderName, classification.productLine);
 var replyOptions = buildReplyOptions_(aiReply, [], ccRecipients);
 var recipientLists = buildUnifiedReplyRecipientLists_(sender, toRecipients, ccRecipients);
