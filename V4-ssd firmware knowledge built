function isMultiQuestionEmail_(text) {
 // Numbered-list style ("2. Wipe Data...", "3. Ransomware Scenario") or
 // several distinct question marks signal a multi-part technical email,
 // not a single "tell me about this product" curiosity question.
 if (/(?:^|\n)\s*\d+[.)]\s/.test(text)) return true;
 var questionMarks = (text.match(/\?/g) || []).length;
 return questionMarks >= 2;
}

