function debugKnowledgeSearchScoresFromPreviewSheet_() {
 loadSavedConfigSpreadsheetId_();
 validateConfig_();
 if (!CONFIG.CONFIG_SPREADSHEET_ID) throw new Error("Run setupEditableConfigTemplate_() first.");
 var spreadsheet = SpreadsheetApp.openById(CONFIG.CONFIG_SPREADSHEET_ID);
 var sheet = ensureEmailTestPreviewSheet_(spreadsheet);
 var subject = String(sheet.getRange("B3").getValue() || "");
 var body = String(sheet.getRange("B4").getValue() || "");
 if (!body) {
  log("Paste a sample email into EMAIL_TEST_PREVIEW B4 first.");
  return;
 }

 var classification = classifyEmail_(subject, body);
 var keywords = extractKeywords(subject + " " + body);
 var allowComparative = isComparisonQuery_(subject + " " + body);
 log("Classification: " + classification.category + " / " + classification.productLine);
 log("Keywords: " + keywords.join(", "));
 log("Comparative files allowed: " + allowComparative);
 log("Curated blocks that would fire: "
  + (isGuardPackageSeriesQuery_((subject + " " + body).toLowerCase()) ? "[GuardSeries] " : "")
  + (isWipeDataVsRapidPurgeQuery_((subject + " " + body).toLowerCase()) ? "[WipeVsPurge] " : "")
  + (isProcessorCompatibilityQuery_((subject + " " + body).toLowerCase()) ? "[ProcessorCompat] " : "")
  + (isGeneralDefinitionQuery_((subject + " " + body).toLowerCase()) ? "[Glossary] " : ""));

 var allFiles = getKnowledgeBaseIndex_();
 var scored = [];
 for (var i = 0; i < allFiles.length; i++) {
  var file = allFiles[i];
  var skip = "";
  if (isDisabledProductFile_(file)) skip = "DISABLED_PRODUCT";
  else if (!isSearchableKnowledgeFile_(file)) skip = "NOT_SEARCHABLE";
  else if (!allowComparative && isComparativeFile_(file)) skip = "COMPARATIVE_FILTERED";
  scored.push({
   name: file.name,
   score: skip ? -1 : scoreKnowledgeFile_(file, keywords, classification),
   src: file.sourceType === "kb_lookup_index" ? "AI_KB" : "inventory",
   skip: skip,
   cap: getMaxCharsForKnowledgeFile_(file),
  });
 }
 scored.sort(function(a, b) { return b.score - a.score; });

 log("Top " + Math.min(scored.length, 15) + " of " + scored.length + " scored file(s). "
  + "Top " + CONFIG.MAX_FILES_TO_EXTRACT + " with score > 0 get extracted.");
 for (var j = 0; j < Math.min(scored.length, 15); j++) {
  var entry = scored[j];
  log(" " + (j + 1) + ". [score " + entry.score + "] " + entry.name
   + " (" + entry.src + ", cap " + entry.cap + ")"
   + (entry.skip ? " SKIPPED: " + entry.skip : ""));
 }
}

function listApprovedKnowledgeBase() {
 log(" Listing approved knowledge base folders and documents...\n");

 var totalFiles = 0;
 var totalFolders = 0;

 for (var folderId in APPROVED_FOLDERS) {
  var folderName = APPROVED_FOLDERS[folderId];
  try {
   var folder = DriveApp.getFolderById(folderId);
   log(" " + folderName);
   totalFolders++;

   var allFolderIds = getAllSubfolderIds(folderId);
   var folderFileCount = 0;

   for (var j = 0; j < allFolderIds.length; j++) {
    try {
     var searchFolder = DriveApp.getFolderById(allFolderIds[j]);
     var files = searchFolder.getFiles();
     while (files.hasNext()) {
      var file = files.next();
      if (isApprovedFileType(file.getMimeType())) {
       var label = allFolderIds[j] === folderId ? "" : " (subfolder)";
       log("  " + file.getName() + label);
       folderFileCount++;
       totalFiles++;
      }
     }
    } catch (e) { }
   }

   if (folderFileCount === 0) {
    log(" (no text-readable files)");
   }
   log("");

  } catch (e) {
   log(' Could not access "' + folderName + '": ' + e.message + "\n");
  }
 }

 log(" Summary: " + totalFiles + " readable files across " + totalFolders + " approved folders");
}

function checkAgentStatus() {
 var triggers = ScriptApp.getProjectTriggers();
 var activeCount = 0;
 for (var i = 0; i < triggers.length; i++) {
  if (triggers[i].getHandlerFunction() === "processNewEmails") activeCount++;
 }

 if (activeCount === 0) {
  log(" Agent NOT running run setupAgent() to start");
 } else {
  log(" Agent running " + activeCount + " trigger(s) active, checking every " + CONFIG.TRIGGER_INTERVAL_MINUTES + " minute(s)");
 }
 log(" Auto-reply: " + (CONFIG.ENABLE_AUTO_REPLY ? "ON (fully automated)" : "OFF (drafts only)"));
 log(" Knowledge source: SHAREABLE_DB (" + getShareableDbIndex_().length + " file rows)");
 log(" Pricing sheet: " + PRICING_SHEET_ID);
}
