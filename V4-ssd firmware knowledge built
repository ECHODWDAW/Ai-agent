// ============================================================================
// SECTION 6 OF 20: GMAIL SEARCH AND EMAIL TEXT PARSING
// Build Gmail queries, merge threads, extract plain text, and isolate the latest customer reply.
// ============================================================================

function getUnprocessedThreads() {
 var unreadQuery = buildAgentGmailQuery_(true);
 log(" Gmail unread query: " + unreadQuery);
 var threads = GmailApp.search(unreadQuery, 0, CONFIG.MAX_EMAILS_PER_RUN * 3);

 if (CONFIG.INCLUDE_READ_UNREPLIED_EMAILS && threads.length < CONFIG.MAX_EMAILS_PER_RUN) {
  var readQuery = buildAgentGmailQuery_(false);
  log(" Gmail read-unreplied query: " + readQuery);
  var readThreads = GmailApp.search(readQuery, 0, CONFIG.MAX_EMAILS_PER_RUN * 3);
  threads = mergeThreadsById_(threads, readThreads);
 }

 if (threads.length < CONFIG.MAX_EMAILS_PER_RUN * 2) {
  var followUpQuery = buildAgentFollowUpQuery_();
  log(" Gmail follow-up query: " + followUpQuery);
  var followUpThreads = GmailApp.search(followUpQuery, 0, CONFIG.MAX_EMAILS_PER_RUN * 3);
  threads = mergeThreadsById_(threads, followUpThreads);
 }

 var filtered = filterThreadsAwaitingReply_(threads);
 if (filtered.length !== threads.length) {
  log(" Filtered out " + (threads.length - filtered.length) + " thread(s) where the last message was from us");
 }

 return filtered.slice(0, CONFIG.MAX_EMAILS_PER_RUN);
}

function buildAgentGmailQuery_(unreadOnly) {
 var excludeQuery = CONFIG.EXCLUDE_LABELS.map(function(l) { return "-label:" + l; }).join(" ");
 var query = "in:" + String(CONFIG.GMAIL_LABEL || "inbox").toLowerCase() + " " + excludeQuery;
 if (unreadOnly) {
  query += " is:unread";
 } else {
  query += " is:read -label:" + CONFIG.PROCESSED_LABEL + " newer_than:" + CONFIG.MAX_READ_EMAIL_AGE_DAYS + "d";
 }
 return query;
}

function buildAgentFollowUpQuery_() {
 var excludeQuery = CONFIG.EXCLUDE_LABELS.map(function(l) { return "-label:" + l; }).join(" ");
 return "in:" + String(CONFIG.GMAIL_LABEL || "inbox").toLowerCase() + " "
  + excludeQuery + " label:" + CONFIG.PROCESSED_LABEL
  + " newer_than:" + CONFIG.MAX_READ_EMAIL_AGE_DAYS + "d";
}

function mergeThreadsById_(primaryThreads, secondaryThreads) {
 var seen = {};
 var merged = [];
 function addThread(thread) {
  var id = thread.getId();
  if (seen[id]) return;
  seen[id] = true;
  merged.push(thread);
 }
 for (var i = 0; i < primaryThreads.length; i++) addThread(primaryThreads[i]);
 for (var j = 0; j < secondaryThreads.length; j++) addThread(secondaryThreads[j]);
 return merged;
}

// ============================================================================
// COST FIREWALL: durable per-thread processing state
// Prevents any single conversation from being re-processed (and re-billed
// against the Claude API) unless the customer has actually sent a new message.
// State per thread: handledCount | failedAttempts | timestamp, stored in
// Script Properties and pruned after the follow-up window expires.
// ============================================================================
var THREAD_STATE_PREFIX_ = "thrState_";
var THREAD_STATE_MAX_AGE_MS_ = 8 * 24 * 60 * 60 * 1000; // just past the 7-day follow-up window
var MAX_PROCESSING_ATTEMPTS_ = 3;

function getThreadState_(threadId) {
 try {
  var raw = PropertiesService.getScriptProperties().getProperty(THREAD_STATE_PREFIX_ + threadId);
  if (!raw) return null;
  var parts = String(raw).split("|");
  return {
   count: parseInt(parts[0], 10) || 0,
   attempts: parseInt(parts[1], 10) || 0,
   ts: parseInt(parts[2], 10) || 0,
  };
 } catch (e) {
  return null;
 }
}

function setThreadState_(threadId, count, attempts) {
 try {
  PropertiesService.getScriptProperties().setProperty(
   THREAD_STATE_PREFIX_ + threadId,
   count + "|" + attempts + "|" + Date.now()
  );
 } catch (e) {
  log(" Could not save thread state: " + e.message);
 }
}

function cleanupThreadStates_() {
 // Prunes stale entries; cheap enough to run occasionally from the main loop.
 try {
  var props = PropertiesService.getScriptProperties();
  var all = props.getProperties();
  var now = Date.now();
  for (var key in all) {
   if (key.indexOf(THREAD_STATE_PREFIX_) !== 0) continue;
   var parts = String(all[key]).split("|");
   var ts = parseInt(parts[2], 10) || 0;
   if (now - ts > THREAD_STATE_MAX_AGE_MS_) props.deleteProperty(key);
  }
 } catch (e) {
  log(" Thread state cleanup failed: " + e.message);
 }
}

function filterThreadsAwaitingReply_(threads) {
 var selfEmails = getSelfEmailSet_();
 var kept = [];
 for (var i = 0; i < threads.length; i++) {
  var thread = threads[i];
  try {
   var messages = thread.getMessages();
   if (messages.length === 0) continue;
   var lastMessage = messages[messages.length - 1];
   var lastFrom = extractEmailAddress(lastMessage.getFrom()).toLowerCase();
   if (selfEmails[lastFrom]) {
    // The most recent message in this thread was sent by us.
    // Nothing new to reply to yet.
    continue;
   }
   var state = getThreadState_(thread.getId());
   if (state && messages.length <= state.count) {
    // Cost firewall: we already handled (or quarantined) this exact
    // conversation state. Nothing new has arrived, so never re-bill it.
    continue;
   }
   kept.push(thread);
  } catch (e) {
   log(" Could not inspect thread " + thread.getId() + ": " + e.message);
  }
 }
 return kept;
}

function extractPlainText(message) {
 var text = message.getPlainBody();
 if (!text || text.trim().length === 0) {
  text = message.getBody()
   .replace(/<style[^>]*>[\s\S]*?<\/style>/gi, "")
   .replace(/<script[^>]*>[\s\S]*?<\/script>/gi, "")
   .replace(/<[^>]+>/g, " ")
   .replace(/&nbsp;/g, " ")
   .replace(/&amp;/g, "&")
   .replace(/&lt;/g, "<")
   .replace(/&gt;/g, ">")
   .replace(/\s+/g, " ")
   .trim();
 }
 return text.substring(0, 5000);
}

function extractLatestReplyText_(text) {
 text = String(text || "").replace(/\r\n/g, "\n").replace(/\r/g, "\n");
 var markers = [
  "\nOn ",
  "\nFrom:",
  "\nSent:",
  "\nTo:",
  "\nCc:",
  "\nSubject:",
  "\n-----Original Message-----",
  "\n---------- Forwarded message ---------",
  "\n________________________________",
 ];

 var cutAt = text.length;
 for (var i = 0; i < markers.length; i++) {
  var idx = text.indexOf(markers[i]);
  if (idx > 0 && idx < cutAt) cutAt = idx;
 }

 var lines = text.substring(0, cutAt).split("\n");
 var kept = [];
 for (var j = 0; j < lines.length; j++) {
  var line = lines[j];
  if (/^\s*>/.test(line)) continue;
  if (/^\s*On .+wrote:\s*$/i.test(line)) break;
  kept.push(line);
 }

 var latest = kept.join("\n")
  .replace(/\n{3,}/g, "\n\n")
  .trim();

 return latest || text.trim();
}


// ============================================================================
// SECTION 7 OF 20: CLASSIFICATION, SPAM CHECKS, AND ESCALATION
// Detect support/sales/product intent, weak knowledge, spam, disabled products, and human handoff paths.
// ============================================================================

var SENTIMENT_ESCALATION_TERMS = [
 "angry", "furious", "upset", "unacceptable", "terrible", "awful",
 "complaint", "escalate", "lawsuit", "legal action", "sue",
];

var INCIDENT_ESCALATION_PHRASES = [
 "security breach", "data breach", "data was lost", "lost our data", "lost my data",
 "got hacked", "been hacked", "we were hacked", "i was hacked", "got ransomware",
 "hit by ransomware", "infected with ransomware", "ransomware attack on my",
 "ransomware attacked", "device was compromised", "account was compromised",
 "account compromised",
];

function needsHumanEscalation_(subject, body) {
 var text = (subject + " " + body).toLowerCase();
 if (containsAnyText_(text, SENTIMENT_ESCALATION_TERMS)) return true;
 if (containsAnyText_(text, INCIDENT_ESCALATION_PHRASES)) return true;
 return false;
}

function isBulkPricingInquiry_(subject, body) {
 var text = (String(subject || "") + " " + String(body || "")).toLowerCase();
 return containsAnyText_(text, BULK_PRICING_TERMS);
}

function replyBodyLooksEmpty_(aiReply) {
 var text = String(aiReply || "")
  .replace(/<br\s*\/?>/gi, "\n")
  .replace(/<[^>]+>/g, "")
  .replace(/&nbsp;/g, " ")
  .replace(/&amp;/g, "&")
  .trim();
 text = text.replace(/^(hi|hello|dear|good morning|good afternoon|good evening)\b[^\n]*/i, "").trim();
 text = text.replace(/\n\s*(best regards|regards|thanks|thank you|sincerely|kind regards|warm regards|cheers)[\s\S]*$/i, "").trim();
 return text.length < 30;
}

function buildEscalationAcknowledgementReply_(senderName) {
