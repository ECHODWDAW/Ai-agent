 return "Hi " + escapeHtml_(name) + ",<br><br>"
  + "Thanks for reaching out. I've forwarded your message to our team so someone can follow up with you directly.<br><br>"
  + CONFIG.SUPPORT_SIGN_OFF;
}

function classifyEmail_(subject, body) {
 var text = ((subject || "") + " " + (body || "")).toLowerCase();
 var intent = detectCustomerProductIntent_(text);
 var category = "General";
 var reason = "No strong category pattern matched";
 var confidence = intent.strongScore > 0 ? 0.7 : (intent.score > 0 ? 0.5 : 0.35);
 var shouldSkip = false;
 var shouldEscalate = false;
 var escalationReason = "";

 if (isObviousSpam_(text)) {
  category = "Spam";
  reason = "Matched spam / bulk email pattern";
  confidence = 0.9;
  shouldSkip = true;
 } else if (needsHumanEscalation_(subject, body)) {
  category = "Escalate";
  reason = "Matched negative sentiment or high-risk language";
  confidence = 0.9;
  shouldEscalate = true;
  escalationReason = "Sentiment / risk escalation";
 } else if (containsAnyText_(text, PRICING_KEYWORDS)) {
  category = "Pricing";
  reason = "Matched pricing / quotation terms";
  confidence = 0.85;
 } else if (containsAnyText_(text, ["install", "installation", "setup", "integrate", "integration", "configure", "configuration", "user guide", "manual"])) {
  category = "Installation";
  reason = "Matched installation / setup terms";
  confidence = 0.8;
 } else if (containsAnyText_(text, ["compatible", "compatibility", "processor", "cpu", "requirement", "requirements", "windows 11", "ram", "laptop"])) {
  category = "Compatibility";
  reason = "Matched compatibility / requirement terms";
  confidence = 0.8;
 } else if (containsAnyText_(text, ["trial", "demo", "free trial", "evaluation", "test license", "try"])) {
  category = "Demo / Trial";
  reason = "Matched demo / trial terms";
  confidence = 0.8;
 } else if (containsAnyText_(text, ["issue", "problem", "error", "bug", "not working", "failed", "failure", "support", "help"])) {
  category = "Technical Support";
  reason = "Matched support / issue terms";
  confidence = 0.8;
 }

 return {
  category: category,
  productLine: intent.label,
  productScore: intent.score,
  productTerms: intent.terms || [],
  strongTerms: intent.strongTerms || [],
  weakTerms: intent.weakTerms || [],
  strongProductScore: intent.strongScore || 0,
  weakProductScore: intent.weakScore || 0,
  confidence: confidence,
  shouldSkip: shouldSkip,
  shouldEscalate: shouldEscalate,
  escalationReason: escalationReason,
  reason: reason,
 };
}

function isObviousSpam_(text) {
 return containsAnyText_(text, [
  "unsubscribe", "newsletter", "limited time offer", "seo services",
  "guest post", "casino", "crypto investment", "marketing list",
  "bulk email", "webinar invitation", "do not reply", "noreply",
 ]);
}

function shouldEscalateReply_(replyHtml) {
 var text = replyHtml.toLowerCase();
 return text.indexOf("forwarded your query") >= 0
  || text.indexOf("forwarded their query") >= 0
  || text.indexOf("someone will follow up") >= 0
  || text.indexOf("sales team who will follow up") >= 0;
}

function isKnowledgeContextStrongEnough_(knowledgeContext, classification, subject, body) {
 if (!knowledgeContext || !knowledgeContext.text) return false;
 if (!classification || classification.productLine === "General X-PHY") return true;

 // Multi-topic emails: don't let one weak sub-topic block Claude from
 // answering the parts that DO have documentation. The per-question
 // answer/defer rules in SYSTEM_PROMPT handle the rest once Claude runs.
 var combinedText = normalizeProductPhrases_((subject || "") + " " + (body || ""));
 if (detectCustomerProductIntents_(combinedText).length > 1) {
  return knowledgeContext.docsUsed > 0
   && stripLowValueKnowledgeMarkers_(knowledgeContext.text).length >= CONFIG.MIN_KB_CONTEXT_CHARS_FOR_DIRECT_REPLY;
 }

 var text = stripLowValueKnowledgeMarkers_(knowledgeContext.text);
 if (knowledgeContext.docsUsed <= 0) return false;
 if (text.length < CONFIG.MIN_KB_CONTEXT_CHARS_FOR_DIRECT_REPLY) return false;

 var product = normalizeExclusionName_(classification.productLine);
 var context = normalizeExclusionName_(text + " " + (knowledgeContext.filesUsed || "") + " " + classification.productLine);
 if (product === "server defender" && context.indexOf("server defender") < 0 && context.indexOf("defender") < 0) return false;
 if (product === "deepfake detector" && context.indexOf("deepfake") < 0 && context.indexOf("dfd") < 0) return false;
 if (product === "secure ssd" && context.indexOf("ssd") < 0 && context.indexOf("solid state") < 0 && context.indexOf("secure ssd") < 0) return false;
 if (product === "guard pc application" && context.indexOf("guard") < 0) return false;
 return true;
}

function stripLowValueKnowledgeMarkers_(text) {
 return String(text || "")
  .replace(/\[Image file available for inline embedding:[^\]]+\]/g, "")
  .replace(/=== Document:[\s\S]*?Original link:[^\n]*\n/g, "")
  .replace(/\s+/g, " ")
  .trim();
}

function buildLimitedDocumentationReply_(senderName, productLine) {
 var name = getSafeGreetingName_(senderName) || "there";
 var product = productLine && productLine !== "General X-PHY" ? productLine : "this topic";
 return "Hi " + escapeHtml_(name) + ",<br><br>"
  + "Thanks for asking about <b>" + escapeHtml_(product) + "</b>. I do not have enough approved documentation in the knowledge base yet to give you a detailed answer confidently, so I have forwarded this to our team for a more accurate follow-up shortly.<br><br>"
  + CONFIG.SUPPORT_SIGN_OFF;
}

function isProductTemporarilyDisabled_(productLine) {
 return productLine === "Server Defender" && !CONFIG.SERVER_DEFENDER_ENABLED;
}

function buildTemporarilyUnavailableProductReply_(senderName, productLine) {
