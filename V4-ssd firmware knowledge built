 }
 return false;
}

function inferMimeTypeFromInventoryType_(type) {
 var normalized = normalizeExclusionName_(type);
 if (normalized.indexOf("google doc") >= 0) return "application/vnd.google-apps.document";
 if (normalized.indexOf("google sheet") >= 0) return "application/vnd.google-apps.spreadsheet";
 if (normalized.indexOf("pdf") >= 0) return "application/pdf";
 if (normalized.indexOf("word") >= 0 || normalized.indexOf("docx") >= 0) return "application/vnd.openxmlformats-officedocument.wordprocessingml.document";
 if (normalized.indexOf("powerpoint") >= 0 || normalized.indexOf("pptx") >= 0) return "application/vnd.openxmlformats-officedocument.presentationml.presentation";
 if (normalized.indexOf("excel") >= 0 || normalized.indexOf("xlsx") >= 0) return "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
 if (normalized.indexOf("png") >= 0) return "image/png";
 if (normalized.indexOf("jpeg") >= 0 || normalized.indexOf("jpg") >= 0) return "image/jpeg";
 if (normalized.indexOf("csv") >= 0) return "text/csv";
 if (normalized.indexOf("text") >= 0) return "text/plain";
 return "application/octet-stream";
}

function canonicalProductLineFromInventory_(productLine, category, name) {
 var haystack = normalizeExclusionName_([productLine, category, name].join(" "));
 if (haystack.indexOf("deepfake") >= 0 || haystack.indexOf("dfd") >= 0) return "Deepfake Detector";
 if (haystack.indexOf("guard pc") >= 0 || haystack.indexOf("guard application") >= 0) return "Guard PC Application";
 if (haystack.indexOf("ssd") >= 0 || haystack.indexOf("endpoint solution") >= 0) return "Secure SSD";
 if (haystack.indexOf("management console") >= 0) return "Management Console";
 if (haystack.indexOf("server defender") >= 0) return "Server Defender";
 if (haystack.indexOf("cipher vault") >= 0 || haystack.indexOf("ciphervault") >= 0) return "CipherVault";
 if (haystack.indexOf("trustsign") >= 0) return "TrustSign";
 if (haystack.indexOf("trustrom") >= 0) return "TrustROM";
 if (haystack.indexOf("immutable") >= 0 || haystack.indexOf("stealth") >= 0 || haystack.indexOf("static security") >= 0) return "Static Security";
 return productLine || "General X-PHY";
}


