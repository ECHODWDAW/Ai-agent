function getPromptRulesFromSheet_() {
 var spreadsheet = getEditableConfigSpreadsheet_();
 var sheet = getEditableConfigSheet_(spreadsheet, CONFIG.PROMPT_RULES_SHEET_NAME);
 if (!sheet) return null;

 var rows = sheet.getDataRange().getValues();
 if (rows.length < 2) return "";
 var headers = getConfigHeaderMap_(rows[0]);
 var output = [];
 var currentSection = "";

 for (var i = 1; i < rows.length; i++) {
  if (!isEnabledConfigRow_(rows[i], headers)) continue;
  var section = String(getConfigCell_(rows[i], headers, "section", 2) || getConfigCell_(rows[i], headers, "category", 2) || "").trim();
  var translatedRule = String(getConfigCell_(rows[i], headers, "translated_rule", -1) || getConfigCell_(rows[i], headers, "ai_translated_rule", -1) || "").trim();
  var oldRule = String(getConfigCell_(rows[i], headers, "rule", 2) || "").trim();
  var plainRule = String(getConfigCell_(rows[i], headers, "prompt_request", -1) || getConfigCell_(rows[i], headers, "plain_english_rule", -1) || "").trim();
  var rule = translatedRule || oldRule || plainRule;
  if (!rule) continue;

  if (section && section !== currentSection) {
   output.push("\n" + section + ":");
   currentSection = section;
  }
  output.push("- " + rule);
 }

 return output.join("\n");
}

