  status: status,
  error: "",
  reply: aiReply.substring(0, 500),
  docsUsed: 0,
  category: classification.category,
  productLine: classification.productLine,
  filesUsed: "",
  claudeModel: "SKIPPED_DISABLED_PRODUCT",
