function loadShareableDbIndexFromSheet_() {
 var rows = [];
 try {
  loadSavedConfigSpreadsheetId_();
  if (!CONFIG.CONFIG_SPREADSHEET_ID) return [];
  var spreadsheet = SpreadsheetApp.openById(CONFIG.CONFIG_SPREADSHEET_ID);
  var sheet = spreadsheet.getSheetByName(CONFIG.SHAREABLE_DB_SHEET_NAME);
  if (!sheet) return [];

  var values = sheet.getDataRange().getValues();
  if (values.length < 2) return [];
  var headers = buildInventoryHeaderMap_(values[0]);

  for (var i = 1; i < values.length; i++) {
   var row = values[i];
   var name = getInventoryCell_(row, headers, "name");
   var link = getInventoryCell_(row, headers, "link");
   var type = getInventoryCell_(row, headers, "type");
   var category = getInventoryCell_(row, headers, "category");
   var productLine = getInventoryCell_(row, headers, "productline");
   var path = getInventoryCell_(row, headers, "path");
   var fileId = extractDriveIdFromUrl_(link);

   if (!name || !link || !fileId) continue;
   if (isInventoryFolderType_(type)) continue;
   if (isExcludedInventoryRow_(name, path)) continue;

   rows.push({
    id: fileId,
    name: name,
    mimeType: inferMimeTypeFromInventoryType_(type),
    url: link,
    parentIds: [],
    parentNames: [category, productLine, path],
    category: category,
    productLine: canonicalProductLineFromInventory_(productLine, category, name),
    inventoryType: type,
    path: path,
   });
  }
  log("Loaded " + rows.length + " file(s) from SHAREABLE_DB");
 } catch (e) {
  log("Could not load SHAREABLE_DB index: " + e.message);
 }
 return rows;
}

function getDocumentInventoryIndex_() {
 if (DOCUMENT_INVENTORY_CACHE_) return DOCUMENT_INVENTORY_CACHE_;
 if (!CONFIG.DOCUMENT_INVENTORY_SPREADSHEET_ID) return [];

 var cachedJson = CacheService.getScriptCache().get(DOCUMENT_INVENTORY_CACHE_KEY_);
 if (cachedJson) {
  try {
