 if (isProductInfoQuestion_(queryText) && (isGuidedUseRequestText_(queryText) || isSupportRequestText_(queryText))) {
  return Math.min(limit + 250, 1000);
 }

 if (containsAnyText_(queryText, ["price", "pricing", "cost", "quote", "quotation", "how much", "subscription"])) {
