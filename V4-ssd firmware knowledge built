function systemPromptToRuleRows_(promptText) {
 var rows = [];
 var lines = String(promptText || "").split(/\r?\n/);
 var currentSection = "ROLE";

 for (var i = 0; i < lines.length; i++) {
  var line = String(lines[i] || "").trim();
  if (!line) continue;

  if (isPromptSectionHeading_(line)) {
   currentSection = line.replace(/:$/, "").trim();
   continue;
  }

  if (line.indexOf("- ") === 0) line = line.substring(2).trim();
  if (line) rows.push([true, "", currentSection, line, "Existing system rule"]);
 }

 return rows;
}

function isPromptSectionHeading_(line) {
 if (!/:$/.test(line)) return false;
 if (line.indexOf("<a ") >= 0 || line.indexOf("http") >= 0) return false;
 if (line.indexOf("- ") === 0) return false;
 var heading = line.replace(/:$/, "").replace(/\s*\([^)]*\)\s*/g, "").trim();
 return /^[A-Z0-9 ,&\/+-]+$/.test(heading) && heading.length <= 80;
}

