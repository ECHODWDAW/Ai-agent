function scoreImageCandidate_(fileMeta, intent) {
 var name = normalizeProductPhrases_(fileMeta.name || "");
 var folderText = normalizeProductPhrases_(getFolderTextForFile_(fileMeta));
 var haystack = name + " " + folderText;
 var score = 0;

 if (!isCandidateAllowedForIntent_(fileMeta, intent)) return 0;
 if (isImageSourceFile_(fileMeta)) score += 10;
 if (isImageMimeType_(fileMeta.mimeType)) score += 12;
 if (haystack.indexOf("screenshot") >= 0 || haystack.indexOf("screen shot") >= 0) score += 8;
 if (haystack.indexOf("image") >= 0 || haystack.indexOf("photo") >= 0 || haystack.indexOf("diagram") >= 0) score += 6;
 if (haystack.indexOf("datasheet") >= 0 || haystack.indexOf("data sheet") >= 0 || haystack.indexOf("brochure") >= 0) score += 5;
 if (haystack.indexOf("demo") >= 0 || haystack.indexOf("guide") >= 0) score += 2;

 var strictTerms = getStrictProductImageTerms_(intent.label);
 for (var i = 0; i < strictTerms.length; i++) {
  if (haystack.indexOf(normalizeProductPhrases_(strictTerms[i])) >= 0) score += 10;
 }

 return score;
}

function isCandidateAllowedForIntent_(fileMeta, intent) {
 if (!isImageSourceFile_(fileMeta)) return false;

 if (!intent || intent.score === 0) {
  return isMatchedProductNeutralImage_(fileMeta);
 }

 return fileMatchesIntent_(fileMeta, intent);
}

function fileMatchesIntent_(fileMeta, intent) {
 var haystack = normalizeExclusionName_(String(fileMeta.name || "") + " " + getFolderTextForFile_(fileMeta) + " " + String(fileMeta.productLine || "") + " " + String(fileMeta.category || "") + " " + String(fileMeta.path || ""));
 var strictTerms = getStrictProductImageTerms_(intent.label);
 for (var i = 0; i < strictTerms.length; i++) {
  if (haystack.indexOf(normalizeExclusionName_(strictTerms[i])) >= 0) return true;
 }
 return haystack.indexOf(normalizeExclusionName_(intent.label)) >= 0;
}

function getStrictProductImageTerms_(productLine) {
 var map = {
  "Deepfake Detector": ["deepfake_detector", "deepfake", "dfd"],
  "Server Defender": ["server_defender"],
  "Management Console": ["management_console"],
  "Guard PC Application": ["guard_pc", "guard_pc_application", "guard application"],
  "Secure SSD": ["secure_ssd", "ssd", "nvme"],
  "CipherVault / Secure USB": ["ciphervault", "cipher vault", "secure usb"],
  "Static / Immutable Storage": ["static security", "immutable", "stealth", "toughx"],
  "TrustSign / TrustROM": ["trustsign", "trust sign", "trustrom", "trust rom"],
  "Secure Laptop": ["secure laptop", "ace", "cyberpad", "zepto", "notebook"],
 };
 return map[productLine] || [productLine];
}

function isMatchedProductNeutralImage_(fileMeta) {
