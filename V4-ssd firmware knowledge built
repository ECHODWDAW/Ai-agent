}

function getExcludeExactNameSet_() {
 var set = {};
 for (var i = 0; i < EXCLUDE_EXACT_NAMES.length; i++) {
  var key = normalizeExclusionName_(EXCLUDE_EXACT_NAMES[i]);
  if (key) set[key] = true;
