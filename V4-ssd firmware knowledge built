}

function getFolderTextForFile_(fileMeta) {
 var names = [];
 if (fileMeta.parentNames && fileMeta.parentNames.length > 0) {
  names = names.concat(fileMeta.parentNames);
 }
 var parentIds = fileMeta.parentIds || [];
 for (var i = 0; i < parentIds.length; i++) {
  if (APPROVED_FOLDERS[parentIds[i]]) names.push(APPROVED_FOLDERS[parentIds[i]]);
 }
 return names.join(" ");
