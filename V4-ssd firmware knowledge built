function getEditableConfigSpreadsheet_() {
 if (!CONFIG.CONFIG_SPREADSHEET_ID) return null;
 try {
  return SpreadsheetApp.openById(CONFIG.CONFIG_SPREADSHEET_ID);
 } catch (e) {
  log("Editable config spreadsheet unavailable; using hardcoded fallback config: " + e.message);
  return null;
 }
}

function getEditableConfigSheet_(spreadsheet, sheetName) {
 if (!spreadsheet || !sheetName) return null;
 try {
  return spreadsheet.getSheetByName(sheetName);
 } catch (e) {
  log("Could not open config tab " + sheetName + ": " + e.message);
  return null;
 }
}

function getConfigHeaderMap_(headers) {
 var map = {};
 for (var i = 0; i < headers.length; i++) {
  map[normalizeConfigHeader_(headers[i])] = i;
 }
 return map;
}

function normalizeConfigHeader_(header) {
 return String(header || "").toLowerCase().trim().replace(/[^a-z0-9]+/g, "_").replace(/^_+|_+$/g, "");
}

function getConfigCell_(row, headers, key, fallbackIndex) {
 var normalizedKey = normalizeConfigHeader_(key);
 var index = headers.hasOwnProperty(normalizedKey) ? headers[normalizedKey] : fallbackIndex;
 return index >= 0 && index < row.length ? row[index] : "";
}

function isEnabledConfigRow_(row, headers) {
 var value = getConfigCell_(row, headers, "enabled", 0);
 var text = String(value).toLowerCase().trim();
 return text === "true" || text === "yes" || text === "y" || text === "1" || text === "enabled";
}

function readSingleColumnConfigFromSheet_(spreadsheet, sheetName, fallback, valueHeader) {
 var sheet = getEditableConfigSheet_(spreadsheet, sheetName);
 if (!sheet) return fallback;
 var rows = sheet.getDataRange().getValues();
 if (rows.length < 2) return fallback;

 var headers = getConfigHeaderMap_(rows[0]);
 var values = [];
 for (var i = 1; i < rows.length; i++) {
  if (!isEnabledConfigRow_(rows[i], headers)) continue;
  var value = String(getConfigCell_(rows[i], headers, valueHeader, 1) || "").trim();
  if (value) values.push(value);
 }
 return values.length ? values : fallback;
}

function readSupportLinksFromSheet_(spreadsheet, fallback) {
 var sheet = getEditableConfigSheet_(spreadsheet, CONFIG.SUPPORT_LINKS_SHEET_NAME);
 if (!sheet) return fallback;
 var rows = sheet.getDataRange().getValues();
 if (rows.length < 2) return fallback;

 var headers = getConfigHeaderMap_(rows[0]);
 var links = cloneSupportLinks_(fallback);
 for (var i = 1; i < rows.length; i++) {
  if (!isEnabledConfigRow_(rows[i], headers)) continue;
  var productLine = String(getConfigCell_(rows[i], headers, "product_line", 1) || "").trim();
  var linkType = String(getConfigCell_(rows[i], headers, "link_type", 2) || "").trim();
  var label = String(getConfigCell_(rows[i], headers, "label", 3) || "").trim();
  var url = String(getConfigCell_(rows[i], headers, "url", 4) || "").trim();
  if (!productLine || !linkType || !label || !url) continue;
  if (!links[productLine]) links[productLine] = {};
  links[productLine][linkType] = { label: label, url: url };
 }
 return Object.keys(links).length ? links : fallback;
}

function cloneSupportLinks_(links) {
 var cloned = {};
 for (var productLine in links) {
  cloned[productLine] = {};
  for (var linkType in links[productLine]) {
   cloned[productLine][linkType] = {
    label: links[productLine][linkType].label,
    url: links[productLine][linkType].url,
   };
  }
 }
 return cloned;
}

function getSystemPrompt_() {
