function collectAllApprovedFileMetadata_() {
 var allFiles = [];
 var seenIds = {};

 for (var folderId in APPROVED_FOLDERS) {
  var folderName = APPROVED_FOLDERS[folderId];
  try {
   var folderIds = getAllSubfolderIds(folderId);

     for (var j = 0; j < folderIds.length; j++) {
      try {
       var folder = DriveApp.getFolderById(folderIds[j]);
       var indexedFolderName = folder.getName();
       var files = folder.getFiles();
       while (files.hasNext()) {
      var file = files.next();
      var fileId = file.getId();
      if (isExcludedDriveName_(file.getName(), false)) {
       log('  Skipping excluded file: "' + file.getName() + '"');
       continue;
      }
      if (!seenIds[fileId] && isApprovedFileType(file.getMimeType())) {
       seenIds[fileId] = true;
       allFiles.push({
        id: fileId,
        name: file.getName(),
        mimeType: file.getMimeType(),
        url: file.getUrl(),
        parentIds: [folderIds[j]],
        parentNames: [indexedFolderName],
       });
      } else if (seenIds[fileId]) {
       for (var f = 0; f < allFiles.length; f++) {
        if (allFiles[f].id === fileId && allFiles[f].parentIds.indexOf(folderIds[j]) < 0) {
         allFiles[f].parentIds.push(folderIds[j]);
         allFiles[f].parentNames.push(indexedFolderName);
         break;
        }
       }
      }
     }
    } catch (e) { }
   }
  } catch (e) {
   log(' Could not access "' + folderName + '": ' + e.message);
  }
 }

 return allFiles;
}

function extractFileContentByMetadata_(fileMeta) {
 // FAQ/knowledgebase docs get a higher extraction cap so the back half
 // (Hardware, Warranty, Cybersecurity, Differentiators) is not silently
 // truncated at 10,000 characters. All extractors read the cap from
 // CONFIG.MAX_CHARS_PER_FILE, so swap it for this one call and restore it.
 var defaultCap = CONFIG.MAX_CHARS_PER_FILE;
 var cap = getMaxCharsForKnowledgeFile_(fileMeta);
 if (cap !== defaultCap) {
  log(' Using extended char cap (' + cap + ') for "' + fileMeta.name + '"');
 }
 try {
  CONFIG.MAX_CHARS_PER_FILE = cap;
  return extractFileContent(DriveApp.getFileById(fileMeta.id));
 } finally {
  CONFIG.MAX_CHARS_PER_FILE = defaultCap;
 }
}

function getMaxCharsForKnowledgeFile_(fileMeta) {
 var haystack = normalizeExclusionName_(
