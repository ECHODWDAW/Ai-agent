function getAllSubfolderIds(parentFolderId) {
 var folderIds = [parentFolderId];

 try {
  var parentFolder = DriveApp.getFolderById(parentFolderId);
  var subfolders = parentFolder.getFolders();

  while (subfolders.hasNext()) {
   var subfolder = subfolders.next();
   var subfolderName = subfolder.getName();

   if (isFolderExcluded(subfolderName)) {
    log('  Skipping excluded folder: "' + subfolderName + '"');
    continue;
   }

   var subId = subfolder.getId();
   folderIds.push(subId);

   try {
    var deeperFolders = subfolder.getFolders();
    while (deeperFolders.hasNext()) {
     var deeper = deeperFolders.next();
     if (!isFolderExcluded(deeper.getName())) {
