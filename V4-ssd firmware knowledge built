// SECTION 14 OF 20: CACHE AND INVENTORY INDEXES
// Warm/read/write knowledge caches and load optional spreadsheet-based KB/inventory indexes.
// ============================================================================

function warmKnowledgeBaseCache_() {
 getKnowledgeBaseIndex_();
}

function getKnowledgeBaseIndex_() {
 if (KB_FILE_INDEX_CACHE_) return KB_FILE_INDEX_CACHE_;

 var cachedIndex = getKBIndexFromCache_();
 if (cachedIndex) {
  KB_FILE_INDEX_CACHE_ = cachedIndex;
  log("Loaded knowledge base index from script cache");
  return KB_FILE_INDEX_CACHE_;
 }

 // Priority: AI_KB enrichment + SHAREABLE_DB allowed inventory > legacy
 // document inventory spreadsheet. Drive crawl and APPROVED_FOLDERS are no
 // longer used.
 var lookupIndex = getKnowledgeLookupIndex_();
 var shareableDbIndex = getShareableDbIndex_();
 var inventoryIndex = shareableDbIndex.length > 0 ? shareableDbIndex : getDocumentInventoryIndex_();

 KB_FILE_INDEX_CACHE_ = mergeKnowledgeIndexes_(lookupIndex, inventoryIndex);
 if (KB_FILE_INDEX_CACHE_.length === 0) {
  log("WARNING: knowledge base index is empty. Run syncShareableDbToEthanConfig_() to populate SHAREABLE_DB.");
 }
 setKBIndexToCache_(KB_FILE_INDEX_CACHE_);
 return KB_FILE_INDEX_CACHE_;
}

function mergeKnowledgeIndexes_(lookupIndex, inventoryIndex) {
 lookupIndex = lookupIndex || [];
 inventoryIndex = inventoryIndex || [];
 if (lookupIndex.length === 0) return inventoryIndex;
 if (inventoryIndex.length === 0) return lookupIndex;

 var byKey = {};
 var merged = [];
 for (var i = 0; i < inventoryIndex.length; i++) {
  var inventoryFile = inventoryIndex[i];
  var inventoryKey = getKnowledgeFileMergeKey_(inventoryFile);
  if (!inventoryKey) continue;
  byKey[inventoryKey] = inventoryFile;
 }

 for (var j = 0; j < lookupIndex.length; j++) {
  var lookupFile = lookupIndex[j];
  var lookupKey = getKnowledgeFileMergeKey_(lookupFile);
  var matchingInventoryFile = lookupKey ? byKey[lookupKey] : null;
  merged.push(mergeKnowledgeFileMetadata_(lookupFile, matchingInventoryFile));
  if (lookupKey && matchingInventoryFile) delete byKey[lookupKey];
 }

 for (var key in byKey) {
  merged.push(byKey[key]);
 }

 log("Merged knowledge index: " + lookupIndex.length + " AI_KB row(s), " + inventoryIndex.length + " inventory row(s), " + merged.length + " searchable row(s)");
 return merged;
}

function mergeKnowledgeFileMetadata_(primary, fallback) {
 if (!fallback) return primary;
 var merged = {};
 for (var fallbackKey in fallback) merged[fallbackKey] = fallback[fallbackKey];
 for (var primaryKey in primary) {
  if (primary[primaryKey] !== "" && primary[primaryKey] !== null && primary[primaryKey] !== undefined) {
   merged[primaryKey] = primary[primaryKey];
  }
 }
 merged.parentNames = uniqueTextList_([]
  .concat(fallback.parentNames || [])
  .concat(primary.parentNames || []));
 return merged;
}

function getKnowledgeFileMergeKey_(fileMeta) {
 if (!fileMeta) return "";
 if (fileMeta.id) return "id:" + String(fileMeta.id);
 if (fileMeta.url) return "url:" + String(fileMeta.url).toLowerCase().trim();
 return "";
}

function getKBIndexFromCache_() {
 try {
  var cachedJson = CacheService.getScriptCache().get(KB_FILE_INDEX_CACHE_KEY_);
  if (!cachedJson) return null;

  var parsed = JSON.parse(cachedJson);
  if (!Array.isArray(parsed)) return null;
  return parsed;
 } catch (e) {
  log("Could not read knowledge base cache: " + e.message);
  return null;
 }
}

function setKBIndexToCache_(index) {
 try {
  CacheService.getScriptCache().put(
   KB_FILE_INDEX_CACHE_KEY_,
   JSON.stringify(index),
   CONFIG.KB_CACHE_TTL_SECONDS
  );
 } catch (e) {
  log("Could not write knowledge base cache: " + e.message);
 }
}

function clearKnowledgeBaseCache_() {
